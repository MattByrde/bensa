        },
        "m_step_1": {
          "type": "step",
          "settings": {
            "title": "IL DESIGNER",
            "text": "Il nostro processo inizia nelle mani del designer, dove generazioni di esperienza vengono sviluppate a partire da uno schizzo fatto a mano e trasformate dal nostro team di ingegneri. Le finiture sono determinate con la massima qualità degli interni in mente, per garantire la longevità di ogni pezzo."
          }
        },
        "m_step_2": {
          "type": "step",
          "settings": {
            "title": "L'ARTIGIANO",
            "text": "Il progetto viene poi affidato all'artigiano per dare vita alla forma e alla struttura. Ore dedicate alla sagomatura, levigatura, assemblaggio e cucitura con il tocco della mano umana, poi meticolosamente ispezionato per il controllo qualità su ogni pezzo."
          }
        },
        "m_step_3": {
          "type": "step",
          "settings": {
            "title": "IL REALIZZATORE",
            "text": "Un prototipo finale viene poi passato ai laboratori dei realizzatori per essere prodotto, curando ogni minimo dettaglio: tessuti, cuciture, stampe e timbri applicati, e firmato ad ogni passaggio."
          }
        }
      },
