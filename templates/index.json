    "testimonials": {
      "type": "testimonials",
      "settings": {},
      "blocks": {
        "testimonial_1": {
          "type": "testimonial",
          "settings": {
            "quote": "La qualità artigianale è straordinaria. Il nostro nuovo divano è il pezzo forte del salotto.",
            "author": "Sara M."
          }
        },
        "testimonial_2": {
          "type": "testimonial",
          "settings": {
            "quote": "Mobili bellissimi e costruiti per durare. Abbiamo arredato tutta la casa con Bensa.",
            "author": "Giovanni T."
          }
        },
        "testimonial_3": {
          "type": "testimonial",
          "settings": {
            "quote": "Consegna veloce e i mobili sono ancora più belli dal vivo. Consigliatissimi per chi cerca arredamento di qualità.",
            "author": "Elena R."
          }
        },
        "testimonial_4": {
          "type": "testimonial",
          "settings": {
            "quote": "L'attenzione ai dettagli è notevole. Ogni angolo, ogni finitura parla di qualità.",
            "author": "Marco L."
          }
        },
        "testimonial_5": {
          "type": "testimonial",
          "settings": {
            "quote": "Adoriamo come i mobili si integrano perfettamente con lo stile della nostra casa. Eleganti e funzionali.",
            "author": "Anna B."
          }
        },
        "testimonial_6": {
          "type": "testimonial",
          "settings": {
            "quote": "Servizio clienti eccezionale e il tavolo da pranzo ha superato ogni aspettativa.",
            "author": "Luca R."
          }
        }
      },
