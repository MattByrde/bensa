    "the_method": {
      "type": "custom-method",
      "blocks": {
        "m_intro": {
          "type": "intro",
          "settings": {
            "heading": "Il Metodo Bensa",
            "text": "Non vintage, non moderno. Il nostro metodo di design prende un approccio raccolto e autentico, utilizzando pezzi ben costruiti con carattere senza tempo, a prescindere dalla loro età. Da Bensa, crediamo che il carattere sia la pietra angolare degli interni senza tempo. Creiamo pezzi fatti per invecchiare e vivere attraverso le generazioni.",
            "link_label": "SCOPRI DI PIÙ",
            "link": ""
          }
        },
        "m_media_1": {
