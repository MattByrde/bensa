          "settings": {
            "eyebrow": "Cucine & Armadi",
            "brand_name": "Poliform",
            "is_sans": true,
            "copy": "Il design italiano come sistema abitativo. Cucine, armadi e walk-in progettati per dialogare con il resto della casa.",
            "meta_1": "Inverigo, IT",
            "meta_2": "Partner dal 2001",
            "cta_label": "Scopri Poliform"
          }
        },
        "spot_gubi": {
          "type": "spotlight",
          "settings": {
            "eyebrow": "Illuminazione & Sedute",
            "brand_name": "Gubi",
            "is_sans": true,
            "copy": "Riscoperte del '900 scandinavo e francese, in dialogo con designer contemporanei. Una collezione curata come un archivio.",
            "meta_1": "Copenhagen, DK",
            "meta_2": "Esclusiva Piemonte",
            "cta_label": "Scopri Gubi"
          }
