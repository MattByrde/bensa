[
  {
    "name": "theme_info",
    "theme_name": "Bensa",
    "theme_version": "1.0.0",
    "theme_author": "Simpol",
    "theme_documentation_url": "https://bensa-arredamenti.myshopify.com",
    "theme_support_url": "https://bensa-arredamenti.myshopify.com"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Primary colors"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FAF8F5"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#2C2C2C"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#A67C52"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary accent",
        "default": "#8B9D77"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Borders",
        "default": "#E5E0DA"
      },
      {
        "type": "header",
        "content": "Button colors"
      },
      {
        "type": "color",
        "id": "color_button_bg",
        "label": "Button background",
        "default": "#2C2C2C"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_button_hover",
        "label": "Button hover",
        "default": "#A67C52"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "assistant_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      }
    ]
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "Logo width",
        "min": 50,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 120
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Social accounts"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_twitter",
        "label": "X (Twitter) URL"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_notes_enable",
        "label": "Enable cart notes",
        "default": true
      }
    ]
  },
  {
    "name": "Search",
    "settings": [
      {
        "type": "checkbox",
        "id": "predictive_search_enabled",
        "label": "Enable predictive search",
        "default": true
      }
    ]
  }
]
