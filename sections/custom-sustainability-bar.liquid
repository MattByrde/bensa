<link rel="stylesheet" href="{{ 'section-custom-sustainability-bar.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-sustainability-bar.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<div class="sustainability-bar">
  <div class="sustainability-bar__inner">

    <div class="sustainability-bar__text">
      {%- if section.settings.heading != blank -%}
        <p class="sustainability-bar__heading">{{ section.settings.heading }}</p>
      {%- endif -%}
      {%- if section.settings.link_label != blank and section.settings.link_url != blank -%}
        <a href="{{ section.settings.link_url }}" class="sustainability-bar__link">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>

    <div class="sustainability-bar__divider"></div>

    {%- if section.blocks.size > 0 -%}
      <div class="sustainability-bar__logos">
        {%- for block in section.blocks -%}
          {%- if block.settings.image != blank -%}
            <div class="sustainability-bar__logo" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" target="_blank" rel="noopener" aria-label="{{ block.settings.alt }}">
                  {{ block.settings.image | image_url: height: 80 | image_tag: loading: 'lazy', alt: block.settings.alt }}
                </a>
              {%- else -%}
                {{ block.settings.image | image_url: height: 80 | image_tag: loading: 'lazy', alt: block.settings.alt }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Sustainability Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Il nostro impegno per le pratiche responsabili."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link Label",
      "default": "Scopri progetto"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Certification Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Sustainability Bar",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
