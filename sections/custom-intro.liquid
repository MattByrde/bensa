{{ 'section-custom-intro.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="intro-section">
  <div class="intro-section__top">
    {%- assign media_blocks = section.blocks | where: 'type', 'media' -%}
    
    <div class="intro-section__cell intro-section__col-1 intro-section__reveal">
      {%- if section.settings.heading != blank -%}
        <h2 class="intro-section__heading text-uppercase">{{ section.settings.heading | newline_to_br }}</h2>
      {%- endif -%}
      
      {%- if media_blocks[1] != blank -%}
      <div class="intro-section__media-wrap intro-section__media-wrap--2" {{ media_blocks[1].shopify_attributes }}>
        {%- if media_blocks[1].settings.video != blank -%}
          {{ media_blocks[1].settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_blocks[1].settings.image != blank -%}
          {{ media_blocks[1].settings.image | image_url: width: 800 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>

    <div class="intro-section__cell intro-section__col-2 intro-section__reveal intro-section__reveal--delay-1">
      {%- if media_blocks[0] != blank -%}
      <div class="intro-section__media-wrap intro-section__media-wrap--1" {{ media_blocks[0].shopify_attributes }}>
        {%- if media_blocks[0].settings.video != blank -%}
          {{ media_blocks[0].settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_blocks[0].settings.image != blank -%}
          {{ media_blocks[0].settings.image | image_url: width: 600 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
      {%- endif -%}

      <div class="intro-section__text-block">
        {%- if section.settings.description != blank -%}
          <div class="intro-section__description typo-body">{{ section.settings.description }}</div>
        {%- endif -%}
        
        {%- if section.settings.header_button_label != blank -%}
          <a href="{{ section.settings.header_button_link | default: '#' }}" class="intro-section__link typo-small">
            {{ section.settings.header_button_label }} 
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M1 5.5h10M7.5 2l3.5 3.5L7.5 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="intro-section__cell intro-section__col-3 intro-section__reveal intro-section__reveal--delay-2">
      {%- if media_blocks[2] != blank -%}
      <div class="intro-section__media-wrap intro-section__media-wrap--3" {{ media_blocks[2].shopify_attributes }}>
        {%- if media_blocks[2].settings.video != blank -%}
          {{ media_blocks[2].settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_blocks[2].settings.image != blank -%}
          {{ media_blocks[2].settings.image | image_url: width: 800 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
      {%- endif -%}

      {%- if section.settings.quote != blank -%}
        <div class="intro-section__caption typo-caption text-uppercase">{{ section.settings.quote }}</div>
      {%- endif -%}
    </div>

    <div class="intro-section__cell intro-section__col-4 intro-section__reveal intro-section__reveal--delay-3">
      {%- if media_blocks[3] != blank -%}
      <div class="intro-section__media-wrap intro-section__media-wrap--4" {{ media_blocks[3].shopify_attributes }}>
        {%- if media_blocks[3].settings.video != blank -%}
          {{ media_blocks[3].settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_blocks[3].settings.image != blank -%}
          {{ media_blocks[3].settings.image | image_url: width: 800 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- endif -%}
      </div>
      {%- endif -%}
    </div>
  </div>
</div>

  {%- comment -%} Impact in Numbers {%- endcomment -%}
  <div class="intro-section__impact intro-section__reveal">
    <div class="intro-section__impact-header">
      <h3 class="typo-section-heading intro-section__impact-title">{{ section.settings.impact_heading | remove: '<p>' | remove: '</p>' | replace: '&lt;', '<' | replace: '&gt;', '>' }}</h3>
    </div>
    <div class="intro-section__impact-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'impact' -%}
          <div class="impact-card" {{ block.shopify_attributes }}>
            <div class="impact-card__number">{{ block.settings.number }}</div>
            <div class="impact-card__text">{{ block.settings.text }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Why Serious Business / Featured Work {%- endcomment -%}
  <div class="intro-section__features intro-section__reveal">
    <div class="intro-section__features-header">
      <h3 class="typo-section-heading intro-section__features-title">{{ section.settings.services_heading | remove: '<p>' | remove: '</p>' | replace: '&lt;', '<' | replace: '&gt;', '>' }}</h3>
      <div class="intro-section__features-desc-wrap">
        {%- if section.settings.services_description != blank -%}
          <div class="intro-section__features-desc typo-body">{{ section.settings.services_description }}</div>
        {%- endif -%}
        {%- if section.settings.services_button_label != blank -%}
          <a href="{{ section.settings.services_button_link }}" class="intro-section__link typo-small">
            {{ section.settings.services_button_label }}
          </a>
        {%- endif -%}
      </div>
    </div>
    <div class="intro-section__features-wrapper">
      <div class="intro-section__features-carousel" data-intro-carousel>
        {%- for block in section.blocks -%}
          {%- if block.type == 'service' -%}
            <a class="intro-feature" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
              <div class="intro-feature__media">
                {%- if block.settings.video != blank -%}
                  {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
                {%- elsif block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="intro-feature__tags">
                {%- assign tags = block.settings.number | split: ',' -%}
                {%- for tag in tags -%}
                   <span class="intro-feature__tag">{{ tag | strip }}</span>
                {%- endfor -%}
              </div>
              <h4 class="typo-card-title intro-feature__title">{{ block.settings.title }}</h4>
              <div class="intro-feature__text">{{ block.settings.text }}</div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="intro-section__features-nav">
        <button class="intro-section__features-arrow intro-section__features-arrow--prev" data-intro-prev aria-label="Previous" disabled>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="intro-section__features-arrow intro-section__features-arrow--next" data-intro-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </div>


<script>
  (function () {
    const section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    const reveals = section.querySelectorAll('.intro-section__reveal');
    const inEditor = window.Shopify && window.Shopify.designMode;

    if (inEditor) {
      reveals.forEach((el) => el.classList.add('is-visible'));
    } else {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
      );

      reveals.forEach((el) => observer.observe(el));
    }

    /* ── Features carousel arrows ── */
    var carousel = section.querySelector('[data-intro-carousel]');
    var prevBtn = section.querySelector('[data-intro-prev]');
    var nextBtn = section.querySelector('[data-intro-next]');

    if (carousel && prevBtn && nextBtn) {
      var cards = carousel.querySelectorAll('.intro-feature');
      var currentIndex = 0;

      function getCardStep() {
        if (!cards.length) return 350;
        return cards[0].offsetWidth + 20; /* card width + gap */
      }

      function goTo(index) {
        var maxIndex = cards.length - 1;
        currentIndex = Math.max(0, Math.min(index, maxIndex));
        carousel.scrollTo({ left: currentIndex * getCardStep(), behavior: 'smooth' });
      }

      function updateArrows() {
        var scrollLeft = Math.round(carousel.scrollLeft);
        var step = getCardStep();
        currentIndex = Math.round(scrollLeft / step);
        prevBtn.disabled = currentIndex <= 0;
        nextBtn.disabled = currentIndex >= cards.length - 1;
      }

      prevBtn.addEventListener('click', function () {
        goTo(currentIndex - 1);
      });

      nextBtn.addEventListener('click', function () {
        goTo(currentIndex + 1);
      });

      carousel.addEventListener('scroll', updateArrows, { passive: true });
      updateArrows();

      /* ── Drag to scroll (disabled in Theme Editor) ── */
      if (!inEditor) {
        var isPointerDown = false;
        var isDragging = false;
        var startX = 0;
        var scrollStart = 0;
        var DRAG_THRESHOLD = 6;

        carousel.addEventListener('mousedown', function (e) {
          isPointerDown = true;
          isDragging = false;
          startX = e.pageX;
          scrollStart = carousel.scrollLeft;
        });

        window.addEventListener('mousemove', function (e) {
          if (!isPointerDown) return;
          var dx = e.pageX - startX;
          if (!isDragging && Math.abs(dx) > DRAG_THRESHOLD) {
            isDragging = true;
            carousel.style.cursor = 'grabbing';
            carousel.style.scrollSnapType = 'none';
          }
          if (isDragging) {
            carousel.scrollLeft = scrollStart - dx;
            e.preventDefault();
          }
        });

        window.addEventListener('mouseup', function () {
          if (!isPointerDown) return;
          isPointerDown = false;
          if (isDragging) {
            isDragging = false;
            carousel.style.cursor = '';
            carousel.style.scrollSnapType = 'x mandatory';
          }
        });

        carousel.addEventListener('click', function (e) {
          if (isDragging) {
            e.preventDefault();
            e.stopPropagation();
          }
        }, true);
      }

      /* ── Theme Editor: scroll selected block into view ── */
      if (inEditor) {
        document.addEventListener('shopify:block:select', function (event) {
          var block = event.target;
          if (!carousel.contains(block)) return;
          var blockRect = block.getBoundingClientRect();
          var carouselRect = carousel.getBoundingClientRect();
          var offset = blockRect.left - carouselRect.left + carousel.scrollLeft;
          carousel.scrollTo({ left: offset - 20, behavior: 'smooth' });
        });
      }
    }
  })();
</script>

