{{ 'section-custom-intro.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="intro-section">
  {%- comment -%} Header {%- endcomment -%}
  <div class="intro-section__header intro-section__reveal">
    {%- if section.settings.heading != blank -%}
      <h2 class="intro-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  {%- comment -%}
    4-column grid:
    Left 3 cols: img1 | img2 | text card
    Right 1 col: img3
  {%- endcomment -%}
  <div class="intro-section__grid">
    <div class="intro-section__left">
      <div class="intro-section__cell intro-section__cell--img1 intro-section__reveal intro-section__reveal--delay-1">
        {%- assign media_block = section.blocks[0] -%}
        {%- if media_block and media_block.settings.video != blank -%}
          {{ media_block.settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_block and media_block.settings.image != blank -%}
          {{ media_block.settings.image | image_url: width: 600 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="intro-section__cell intro-section__cell--img2 intro-section__reveal intro-section__reveal--delay-2">
        {%- assign media_block = section.blocks[1] -%}
        {%- if media_block and media_block.settings.video != blank -%}
          {{ media_block.settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_block and media_block.settings.image != blank -%}
          {{ media_block.settings.image | image_url: width: 600 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      <div class="intro-section__cell intro-section__cell--text intro-section__reveal intro-section__reveal--delay-3">
        {%- if section.settings.description != blank -%}
          <div class="intro-section__description">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
        {%- if section.settings.quote != blank -%}
          <div class="intro-section__quote-wrap">
            <blockquote class="intro-section__quote">
              {{ section.settings.quote }}
            </blockquote>
            {%- if section.settings.signature_image != blank -%}
              <div class="intro-section__signature">
                {{ section.settings.signature_image | image_url: width: 200 | image_tag: class: 'intro-section__signature-img', loading: 'lazy' }}
              </div>
            {%- elsif section.settings.signature_text != blank -%}
              <p class="intro-section__signature-text">{{ section.settings.signature_text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="intro-section__right">
      <div class="intro-section__cell intro-section__cell--img3 intro-section__reveal intro-section__reveal--delay-4">
        {%- assign media_block = section.blocks[2] -%}
        {%- if media_block and media_block.settings.video != blank -%}
          {{ media_block.settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
        {%- elsif media_block and media_block.settings.image != blank -%}
          {{ media_block.settings.image | image_url: width: 400 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
        {%- else -%}
          <div class="intro-section__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    const reveals = section.querySelectorAll('.intro-section__reveal');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    reveals.forEach((el) => observer.observe(el));
  })();
</script>

{% schema %}
{
  "name": "Intro",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f0e8"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ispirazione per ogni ambiente"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Il nostro fondatore, Marco Bensa, con decenni di esperienza nel mondo dell'arredamento d'interni, ha dedicato la sua vita alla ricerca della qualità e del design italiano.</p>"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "\"La mia passione per il design e l'attenzione ai dettagli si riflettono in ogni ambiente che creiamo.\""
    },
    {
      "type": "image_picker",
      "id": "signature_image",
      "label": "Signature Image"
    },
    {
      "type": "text",
      "id": "signature_text",
      "label": "Signature Text",
      "default": "Marco Bensa"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Media",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Intro",
      "blocks": [
        { "type": "media" },
        { "type": "media" },
        { "type": "media" }
      ]
    }
  ]
}
{% endschema %}
