{{ 'section-custom-intro.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="intro-section">
  {%- comment -%} Header {%- endcomment -%}
  <div class="intro-section__header intro-section__reveal">
    {%- if section.settings.heading != blank -%}
      <h2 class="intro-section__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>

  {%- comment -%}
    4-column grid:
    Left 3 cols: img1 | img2 | text card
    Right 1 col: img3
  {%- endcomment -%}
  <div class="intro-section__grid">
    <div class="intro-section__left">
      {%- assign media_blocks = section.blocks | where: 'type', 'media' -%}
      {%- for block in media_blocks limit: 2 -%}
        <div class="intro-section__cell intro-section__cell--img{{ forloop.index }} intro-section__reveal intro-section__reveal--delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
          {%- else -%}
            <div class="intro-section__placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <div class="intro-section__cell intro-section__cell--text intro-section__reveal intro-section__reveal--delay-3">
        {%- if section.settings.description != blank -%}
          <div class="intro-section__description">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
        {%- if section.settings.quote != blank -%}
          <div class="intro-section__quote-wrap">
            <blockquote class="intro-section__quote">
              {{ section.settings.quote }}
            </blockquote>
            {%- if section.settings.signature_image != blank -%}
              <div class="intro-section__signature">
                {{ section.settings.signature_image | image_url: width: 200 | image_tag: class: 'intro-section__signature-img', loading: 'lazy' }}
              </div>
            {%- elsif section.settings.signature_text != blank -%}
              <p class="intro-section__signature-text">{{ section.settings.signature_text }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="intro-section__right">
      {%- assign media_blocks = section.blocks | where: 'type', 'media' -%}
      {%- for block in media_blocks offset: 2 limit: 1 -%}
        <div class="intro-section__cell intro-section__cell--img3 intro-section__reveal intro-section__reveal--delay-4" {{ block.shopify_attributes }}>
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: class: 'intro-section__video', autoplay: true, loop: true, muted: true, playsinline: true }}
          {%- elsif block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 400 | image_tag: class: 'intro-section__img', loading: 'lazy' }}
          {%- else -%}
            <div class="intro-section__placeholder">
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

  {%- comment -%} Impact in Numbers {%- endcomment -%}
  <div class="intro-section__impact intro-section__reveal">
    <div class="intro-section__impact-header">
      <h2 class="intro-section__impact-title">{{ section.settings.impact_heading }}</h2>
    </div>
    <div class="intro-section__impact-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'impact' -%}
          <div class="impact-card" {{ block.shopify_attributes }}>
            <div class="impact-card__number">{{ block.settings.number }}</div>
            <div class="impact-card__text">{{ block.settings.text }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Why Serious Business / Featured Work {%- endcomment -%}
  <div class="intro-section__features intro-section__reveal">
    <div class="intro-section__features-left">
      <h2 class="intro-section__features-title">{{ section.settings.services_heading }}</h2>
      <div class="intro-section__features-line"></div>
      {%- if section.settings.services_description != blank -%}
        <div class="intro-section__features-desc">{{ section.settings.services_description }}</div>
      {%- endif -%}
    </div>
    <div class="intro-section__features-right">
      <div class="intro-section__features-carousel">
        {%- for block in section.blocks -%}
          {%- if block.type == 'service' -%}
            <div class="intro-feature" {{ block.shopify_attributes }}>
              <div class="intro-feature__media">
                {%- if block.settings.video != blank -%}
                  {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
                {%- elsif block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="intro-feature__tags">
                {%- assign tags = block.settings.number | split: ',' -%}
                {%- for tag in tags -%}
                   <span class="intro-feature__tag">{{ tag | strip }}</span>
                {%- endfor -%}
              </div>
              <div class="intro-feature__title">{{ block.settings.title }}</div>
              <div class="intro-feature__text">{{ block.settings.text }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>


<script>
  (function () {
    const section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    const reveals = section.querySelectorAll('.intro-section__reveal');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    reveals.forEach((el) => observer.observe(el));
  })();
</script>

