{{ 'section-custom-brand-logos.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .brand-logos__track {
    animation-duration: {{ section.settings.speed }}s;
  }
{%- endstyle -%}

<div class="brand-logos">
  {%- if section.settings.heading != blank -%}
    <h2 class="section-heading brand-logos__heading typo-h2">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="brand-logos__marquee">
    <div class="brand-logos__track">
      {%- for block in section.blocks -%}
        <div class="brand-logos__item" {{ block.shopify_attributes }}>
          {%- if block.settings.logo != blank -%}
            {%- assign logo_alt = block.settings.alt_text | default: '' | escape -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}">
                {{ block.settings.logo | image_url: width: 600 | image_tag: class: 'brand-logos__img', loading: 'lazy', alt: logo_alt }}
              </a>
            {%- else -%}
              {{ block.settings.logo | image_url: width: 600 | image_tag: class: 'brand-logos__img', loading: 'lazy', alt: logo_alt }}
            {%- endif -%}
          {%- else -%}
            <div class="brand-logos__placeholder">Logo</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
      {%- for block in section.blocks -%}
        <div class="brand-logos__item" aria-hidden="true">
          {%- if block.settings.logo != blank -%}
            {%- assign logo_alt = block.settings.alt_text | default: '' | escape -%}
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" tabindex="-1">
                {{ block.settings.logo | image_url: width: 300 | image_tag: class: 'brand-logos__img', loading: 'lazy', alt: logo_alt }}
              </a>
            {%- else -%}
              {{ block.settings.logo | image_url: width: 300 | image_tag: class: 'brand-logos__img', loading: 'lazy', alt: logo_alt }}
            {%- endif -%}
          {%- else -%}
            <div class="brand-logos__placeholder">Logo</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Brand Logos",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Solo i migliori marchi a livello mondiale."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "s",
      "label": "Scroll Speed",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt Text",
          "info": "Brand name for accessibility."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
