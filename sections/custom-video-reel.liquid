            "headline": "La <em>LC4</em> nasce a mano, un pezzo alla volta.",
            "duration": "3:12",
            "location": "Meda, IT",
            "context": "Le Corbusier",
            "placeholder_label": "Video · Cassina making-of · 16:9 · 1920×1080"
          }
        },
        {
          "type": "video",
          "settings": {
            "tag": "Salone",
            "kicker": "Poliform · Alea Pro",
            "headline": "La cucina come <em>architettura</em> domestica.",
            "duration": "1:58",
            "location": "Milano",
            "context": "Salone 2026",
            "placeholder_label": "Video · Poliform cucine · Salone 2026 · 16:9"
          }
        },
        {
          "type": "video",
          "settings": {
            "tag": "Atelier",
            "kicker": "Flos · Luce progettata",
            "headline": "Ottant'anni di <em>innovazione italiana</em>.",
            "duration": "4:20",
            "location": "Bovezzo, IT",
            "context": "Castiglioni",
            "placeholder_label": "Video · Flos illuminazione · Bocci atelier · 16:9"
          }
        },
        {
          "type": "video",
          "settings": {
            "tag": "Collezione",
            "kicker": "Minotti · Outdoor 2026",
            "headline": "Vivere <em>fuori</em>, con la stessa cura.",
            "duration": "2:35",
            "location": "Meda, IT",
            "context": "Salone 2026",
            "placeholder_label": "Video · Minotti outdoor · 16:9"
          }
        },
