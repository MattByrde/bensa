{{ 'section-custom-ristrutturazioni-hero.css' | asset_url | stylesheet_tag }}

<div class="rist-hero" data-rist-hero style="min-height: {{ section.settings.height }}vh;">

  {%- comment -%} Slides {%- endcomment -%}
  <div class="rist-hero__slides" data-rist-hero-slides>
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        <div class="rist-hero__slide{% if forloop.first %} is-active{% endif %}" data-rist-hero-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>

          <div class="rist-hero__media">
            {%- if block.settings.video != blank -%}
              <video
                class="rist-hero__video"
                src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
                autoplay muted loop playsinline preload="auto"
              ></video>
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1920 | image_tag: class: 'rist-hero__video-poster', loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
              {%- endif -%}
            {%- elsif block.settings.video_url != blank -%}
              <video
                class="rist-hero__video"
                src="{{ block.settings.video_url }}"
                autoplay muted loop playsinline preload="auto"
              ></video>
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1920 | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                sizes: '100vw',
                widths: '750, 1100, 1500, 1920'
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <div class="rist-hero__overlay"></div>

          <div class="rist-hero__inner">
            <div class="rist-hero__content">
              {%- if block.settings.subtitle != blank -%}
                <span class="rist-hero__subtitle">{{ block.settings.subtitle }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="rist-hero__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <p class="rist-hero__subtext">{{ block.settings.subtext }}</p>
              {%- endif -%}
              <div class="rist-hero__actions">
                {%- if block.settings.button_label != blank -%}
                  <a href="{{ block.settings.button_link | default: '#' }}" class="rist-hero__btn rist-hero__btn--primary typo-btn">
                    {{ block.settings.button_label }}
                  </a>
                {%- endif -%}
                {%- if block.settings.button_label_2 != blank -%}
                  <a href="{{ block.settings.button_link_2 | default: '#' }}" class="rist-hero__btn rist-hero__btn--secondary typo-btn">
                    {{ block.settings.button_label_2 }}
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>

        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- comment -%} Bottom-right controls {%- endcomment -%}
  {%- assign slide_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'slide' -%}
      {%- assign slide_count = slide_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if slide_count > 1 -%}
    <div class="rist-hero__controls" data-rist-hero-controls>
      <div class="rist-hero__counter">
        <span data-rist-hero-current>01</span>
        <span class="rist-hero__counter-sep">/</span>
        <span>{{ slide_count | prepend: '00' | slice: -2, 2 }}</span>
      </div>
      <div class="rist-hero__progress" data-rist-hero-progress>
        <div class="rist-hero__progress-bar" data-rist-hero-bar></div>
      </div>
      <div class="rist-hero__arrows">
        <button class="rist-hero__arrow rist-hero__arrow--prev" data-rist-hero-prev aria-label="Slide precedente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l6-6M5 12l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="rist-hero__arrow rist-hero__arrow--next" data-rist-hero-next aria-label="Slide successiva">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M19 12l-6-6M19 12l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  {%- endif -%}

  <a href="#rist-hero-next" class="rist-hero__scroll" aria-label="Scorri giù">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>

</div>
<span id="rist-hero-next"></span>

<script>
  (function () {
    var hero = document.querySelector('[data-rist-hero]');
    if (!hero) return;

    var slides = hero.querySelectorAll('[data-rist-hero-slide]');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;
    var autoDelay = 6000;
    var timer;
    var counterEl = hero.querySelector('[data-rist-hero-current]');
    var barEl = hero.querySelector('[data-rist-hero-bar]');

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function goTo(idx) {
      slides[current].classList.remove('is-active');
      current = ((idx % total) + total) % total;
      slides[current].classList.add('is-active');
      if (counterEl) counterEl.textContent = pad(current + 1);
      restartBar();
    }

    function restartBar() {
      if (!barEl) return;
      barEl.style.transition = 'none';
      barEl.style.width = '0%';
      barEl.offsetWidth; /* reflow */
      barEl.style.transition = 'width ' + autoDelay + 'ms linear';
      barEl.style.width = '100%';
    }

    function startAuto() {
      restartBar();
      timer = setInterval(function () { goTo(current + 1); }, autoDelay);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    var prevBtn = hero.querySelector('[data-rist-hero-prev]');
    var nextBtn = hero.querySelector('[data-rist-hero-next]');

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); resetAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); resetAuto(); });

    /* Swipe support */
    var startX = 0;
    var dragging = false;

    hero.addEventListener('touchstart', function (e) {
      startX = e.touches[0].clientX;
      dragging = true;
    }, { passive: true });

    hero.addEventListener('touchend', function (e) {
      if (!dragging) return;
      dragging = false;
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 50) {
        goTo(dx < 0 ? current + 1 : current - 1);
        resetAuto();
      }
    });

    startAuto();
  })();
</script>

{% schema %}
{
  "name": "Ristrutturazioni Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine di sfondo"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video di sfondo",
          "info": "Ha priorità sull'immagine."
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "URL video esterno (.mp4)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Sottotitolo",
          "default": "Ristrutturazioni"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Titolo",
          "default": "Ristrutturiamo la tua casa chiavi in mano"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Testo descrittivo",
          "default": "Un unico interlocutore dalla progettazione alla consegna. Qualità artigianale, tempi certi, zero pensieri."
        },
        {
          "type": "header",
          "content": "Pulsante primario"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Testo pulsante",
          "default": "Richiedi un sopralluogo"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link pulsante"
        },
        {
          "type": "header",
          "content": "Pulsante secondario"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Testo pulsante",
          "default": "Scopri il metodo"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Link pulsante"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ristrutturazioni Hero",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "subtitle": "Ristrutturazioni",
            "heading": "Ristrutturiamo la tua casa chiavi in mano",
            "subtext": "Un unico interlocutore dalla progettazione alla consegna. Qualità artigianale, tempi certi, zero pensieri.",
            "button_label": "Richiedi un sopralluogo",
            "button_label_2": "Scopri il metodo"
          }
        }
      ]
    }
  ]
}
{% endschema %}
