{{ 'section-custom-ristrutturazioni-hero.css' | asset_url | stylesheet_tag }}

<div class="rist-hero" style="min-height: {{ section.settings.height }}vh;">

  <div class="rist-hero__media">
    {%- if section.settings.video != blank -%}
      <video
        class="rist-hero__video"
        src="{{ section.settings.video.sources[1].url | default: section.settings.video.sources[0].url }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1920 | image_tag: class: 'rist-hero__video-poster', loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
      {%- endif -%}
    {%- elsif section.settings.video_url != blank -%}
      <video
        class="rist-hero__video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '750, 1100, 1500, 1920'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="rist-hero__overlay"></div>

  <div class="rist-hero__inner">
    <div class="rist-hero__content">
      {%- if section.settings.subtitle != blank -%}
        <span class="rist-hero__subtitle">{{ section.settings.subtitle }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="rist-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="rist-hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="rist-hero__btn typo-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Ristrutturazioni Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video di sfondo",
      "info": "Se impostato, ha priorità sull'immagine."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "URL video esterno (.mp4)",
      "info": "Alternativa al video Shopify. Incolla un URL diretto a un file .mp4."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine di sfondo",
      "info": "Usata come fallback se nessun video è impostato, o come poster del video."
    },
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 75
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sottotitolo",
      "default": "Ristrutturazioni"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Ristrutturiamo il tuo spazio"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Testo introduttivo",
      "default": "Trasformiamo i vostri ambienti con interventi su misura, dalla demolizione alla consegna chiavi in mano."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo pulsante",
      "default": "Contattaci"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link pulsante"
    }
  ],
  "presets": [
    {
      "name": "Ristrutturazioni Hero"
    }
  ]
}
{% endschema %}
