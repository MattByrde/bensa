{{ 'section-custom-hero-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .hero-reviews {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .hero-reviews {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="hero-reviews">
  {%- comment -%} Background media {%- endcomment -%}
  <div class="hero-reviews__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy' }}
    {%- endif -%}
  </div>
  <div class="hero-reviews__overlay"></div>

  {%- comment -%} Hero content {%- endcomment -%}
  <div class="hero-reviews__content hero-reviews__reveal">
    {%- if section.settings.subtitle != blank -%}
      <p class="hero-reviews__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-reviews__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="hero-reviews__description">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} Reviews grid — static cards {%- endcomment -%}
  <div class="hero-reviews__grid hero-reviews__reveal hero-reviews__reveal--delay-2">
    {%- for block in section.blocks -%}
      <div class="hero-reviews__card" {{ block.shopify_attributes }}>
        {%- comment -%} Stars {%- endcomment -%}
        <div class="hero-reviews__stars">
          {%- assign stars = block.settings.stars | default: 5 -%}
          {%- for i in (1..5) -%}
            <svg class="hero-reviews__star{% if i <= stars %} hero-reviews__star--filled{% endif %}" viewBox="0 0 24 24" width="14" height="14">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {%- endfor -%}
        </div>

        {%- comment -%} Review text {%- endcomment -%}
        {%- if block.settings.text != blank -%}
          <p class="hero-reviews__review-text">"{{ block.settings.text }}"</p>
        {%- endif -%}

        {%- comment -%} Divider {%- endcomment -%}
        <div class="hero-reviews__divider"></div>

        {%- comment -%} Author {%- endcomment -%}
        <div class="hero-reviews__author">
          {%- if block.settings.author_image != blank -%}
            <div class="hero-reviews__author-img">
              {{ block.settings.author_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
            </div>
          {%- endif -%}
          <div class="hero-reviews__author-info">
            {%- if block.settings.author_name != blank -%}
              <span class="hero-reviews__author-name">{{ block.settings.author_name }}</span>
            {%- endif -%}
            {%- if block.settings.author_role != blank -%}
              <span class="hero-reviews__author-role">{{ block.settings.author_role }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  (function () {
    var section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    var reveals = section.querySelectorAll('.hero-reviews__reveal');
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
    reveals.forEach(function (el) { observer.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Hero Reviews",
  "tag": "section",
  "class": "section-hero-reviews",
  "settings": [
    {
      "type": "header",
      "content": "Background"
