{{ 'section-custom-hero-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .hero-reviews {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .hero-reviews {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="hero-reviews" style="min-height: {{ section.settings.height }}vh;">
  {%- comment -%} Background media {%- endcomment -%}
  <div class="hero-reviews__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy' }}
    {%- endif -%}
  </div>
  <div class="hero-reviews__overlay"></div>

  {%- comment -%} Hero content {%- endcomment -%}
  <div class="hero-reviews__content hero-reviews__reveal">
    {%- if section.settings.heading != blank -%}
      <h2 class="hero-reviews__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="hero-reviews__description">{{ section.settings.description }}</p>
    {%- endif -%}
    <div class="hero-reviews__actions">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="hero-reviews__btn hero-reviews__btn--primary typo-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 | default: '#' }}" class="hero-reviews__btn hero-reviews__btn--secondary typo-btn">
          {{ section.settings.button_label_2 }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    var reveals = section.querySelectorAll('.hero-reviews__reveal');
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );
    reveals.forEach(function (el) { observer.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Hero Reviews",
  "tag": "section",
  "class": "section-hero-reviews",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background Video",
      "info": "Takes priority over image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spazi che raccontano chi sei"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Ogni progetto nasce dall'ascolto, dalla cura dei dettagli e dalla passione per il design italiano."
    },
    {
      "type": "header",
      "content": "Pulsante primario"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo pulsante",
      "default": "Prenota un appuntamento"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link pulsante"
    },
    {
      "type": "header",
      "content": "Pulsante secondario"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Testo pulsante",
      "default": "Le nostre realizzazioni"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Link pulsante"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Hero Reviews"
    }
  ]
}
{% endschema %}
