{{ 'section-custom-marchi-custom.css' | asset_url | stylesheet_tag }}

<section class="marchi-custom" aria-label="{{ section.settings.aria_label | default: 'Progetti su misura' | escape }}" style="{%- if section.settings.bg_color != blank -%}background-color:{{ section.settings.bg_color }};{%- endif -%}{%- if section.settings.text_color != blank -%}color:{{ section.settings.text_color }};{%- endif -%}">
  <div class="marchi-custom__inner">

    <div class="marchi-custom__media">
      {%- if section.settings.badge_label != blank -%}
        <span class="marchi-custom__badge">{{ section.settings.badge_label }}</span>
      {%- endif -%}
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag:
          loading: 'lazy',
          sizes: '(min-width:990px) 50vw, 100vw',
          widths: '600, 900, 1200, 1600',
          alt: section.settings.image_alt | default: section.settings.kicker }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="marchi-custom__body">
      {%- if section.settings.kicker != blank -%}
        <p class="marchi-custom__kicker">{{ section.settings.kicker }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="typo-section-heading marchi-custom__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="marchi-custom__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="marchi-custom__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bullet' -%}
              <li {{ block.shopify_attributes }}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="4 12 10 18 20 6"/></svg>
                {{ block.settings.text }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.primary_cta_label != blank or section.settings.secondary_cta_label != blank -%}
        <div class="marchi-custom__actions">
          {%- if section.settings.primary_cta_label != blank -%}
            <a href="{{ section.settings.primary_cta_link | default: '#' }}" class="marchi-custom__btn marchi-custom__btn--primary">
              {{ section.settings.primary_cta_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.secondary_cta_label != blank -%}
            <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="marchi-custom__btn marchi-custom__btn--outline">
              {{ section.settings.secondary_cta_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Marchi · Su misura",
  "tag": "section",
  "class": "shopify-section--marchi-custom",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Colori"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore sfondo"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Colore testo"
    },
    {
      "type": "header",
      "content": "Immagine"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Testo alternativo immagine"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Badge sull'immagine",
      "default": "Laboratorio · Piemonte"
    },
    {
      "type": "header",
      "content": "Testo"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Non trovi il tuo brand?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "info": "Usa <em>...</em> per il corsivo serif.",
      "default": "Quando un marchio non basta, <em>disegniamo noi</em> il pezzo."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Descrizione",
      "default": "Collaboriamo con falegnami, tappezzieri e marmisti piemontesi per realizzare arredi su misura: un tavolo a cinque metri che entra in un vano di quattro e ottanta, una libreria che segue la pendenza del tetto, un divano modulare per una stanza che non esiste ancora."
    },
    {
      "type": "header",
      "content": "Azioni"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "CTA principale",
      "default": "Parliamo del tuo progetto"
    },
    {
      "type": "url",
      "id": "primary_cta_link",
      "label": "Link CTA principale"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "CTA secondaria",
      "default": "Vedi realizzazioni su misura"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Link CTA secondaria"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Punto elenco",
      "settings": [
        { "type": "text", "id": "text", "label": "Testo", "default": "Punto elenco" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marchi · Su misura",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Progetto dedicato con disegni tecnici e render" } },
        { "type": "bullet", "settings": { "text": "Campionatura materiali in showroom a Cuneo" } },
        { "type": "bullet", "settings": { "text": "Produzione in Italia, 8–14 settimane" } }
      ]
    }
  ]
}
{% endschema %}
