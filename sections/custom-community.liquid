{{ 'section-custom-community.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="community">

  {%- comment -%} ── Header: heading + descriptions ── {%- endcomment -%}
  <div class="community__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="community__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle_left != blank or section.settings.subtitle_right != blank -%}
      <div class="community__subtitle-row">
        {%- if section.settings.subtitle_left != blank -%}
          <p class="community__subtitle">{{ section.settings.subtitle_left }}</p>
        {%- endif -%}
        {%- if section.settings.subtitle_right != blank -%}
          <p class="community__subtitle">{{ section.settings.subtitle_right }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Video carousel ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="community__carousel">
      <div class="community__track" data-community-track>
        {%- for block in section.blocks -%}
          <div class="community__slide{% if forloop.first %} community__slide--active{% endif %}" {{ block.shopify_attributes }}>
            <div class="community__slide-text">
              {%- if block.settings.username != blank -%}
                <p>@{{ block.settings.username }}</p>
              {%- endif -%}
            </div>
            <div class="community__slide-media">
              {%- if block.settings.video != blank -%}
                <video
                  class="community__video"
                  poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 }}{%- endif -%}"
                  loop
                  muted
                  playsinline
                  preload="metadata"
                  data-community-video
                >
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif block.settings.video_url != blank -%}
                <video
                  class="community__video"
                  src="{{ block.settings.video_url }}"
                  poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 }}{%- endif -%}"
                  loop
                  muted
                  playsinline
                  preload="metadata"
                  data-community-video
                ></video>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'community__video', loading: 'lazy' }}
              {%- else -%}
                <div class="community__placeholder">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="8" fill="#e5e0da"/><path d="M20 16L32 24L20 32V16Z" fill="#999"/></svg>
                </div>
              {%- endif -%}

              {%- if block.settings.video != blank or block.settings.video_url != blank -%}
                <div class="community__controls">
                  <button class="community__control-btn" data-community-play aria-label="Play / Pause">
                    <svg class="community__icon-pause" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="3" y="2" width="4" height="12" rx="1" fill="currentColor"/><rect x="9" y="2" width="4" height="12" rx="1" fill="currentColor"/></svg>
                    <svg class="community__icon-play" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2.5L13 8L4 13.5V2.5Z" fill="currentColor"/></svg>
                  </button>
                  <button class="community__control-btn" data-community-mute aria-label="Mute / Unmute">
                    <svg class="community__icon-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><line x1="11" y1="5" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="15" y1="5" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    <svg class="community__icon-unmuted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><path d="M11 5.5C11.8 6.3 12.25 7.4 12.25 8.5C12.25 9.6 11.8 10.7 11 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 3.5C14.3 4.8 15 6.6 15 8.5C15 10.4 14.3 12.2 13 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

</div>

<script>
  (function() {
    var track = document.querySelector('#shopify-section-{{ section.id }} [data-community-track]');
    if (!track) return;
    var slides = track.querySelectorAll('.community__slide');

    /* Hover: activate slide + auto-play its video */
    slides.forEach(function(slide) {
      slide.addEventListener('mouseenter', function() {
        slides.forEach(function(s) {
          s.classList.remove('community__slide--active');
          var v = s.querySelector('[data-community-video]');
          if (v) { v.pause(); s.querySelector('.community__slide-media').classList.remove('is-playing'); }
        });
        slide.classList.add('community__slide--active');
        var video = slide.querySelector('[data-community-video]');
        if (video) {
          video.play().catch(function(){});
          slide.querySelector('.community__slide-media').classList.add('is-playing');
        }
      });
    });

    /* Play/Pause + Mute toggles */
    track.addEventListener('click', function(e) {
      var playBtn = e.target.closest('[data-community-play]');
      if (playBtn) {
        var media = playBtn.closest('.community__slide-media');
        var video = media.querySelector('[data-community-video]');
        if (!video) return;
        if (video.paused) {
          video.play().catch(function(){});
          media.classList.add('is-playing');
        } else {
          video.pause();
          media.classList.remove('is-playing');
        }
        return;
      }
      var muteBtn = e.target.closest('[data-community-mute]');
      if (muteBtn) {
        var media = muteBtn.closest('.community__slide-media');
        var video = media.querySelector('[data-community-video]');
        if (!video) return;
        video.muted = !video.muted;
        media.classList.toggle('is-unmuted', !video.muted);
      }
    });

    /* Drag to scroll */
    var isDown = false, startX, scrollLeft;
    track.addEventListener('mousedown', function(e) {
      if (e.target.closest('button')) return;
      isDown = true;
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });
    track.addEventListener('mouseleave', function() { isDown = false; });
    track.addEventListener('mouseup', function() { isDown = false; });
    track.addEventListener('mousemove', function(e) {
      if (!isDown) return;
      e.preventDefault();
      var x = e.pageX - track.offsetLeft;
      track.scrollLeft = scrollLeft - (x - startX);
    });

    /* Auto-play first video */
    var firstVideo = slides[0] && slides[0].querySelector('[data-community-video]');
    if (firstVideo) {
      firstVideo.play().catch(function(){});
      var firstMedia = slides[0].querySelector('.community__slide-media');
      if (firstMedia) firstMedia.classList.add('is-playing');
    }
  })();
</script>

{% schema %}
{
  "name": "Community",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "La Community"
    },
    {
      "type": "textarea",
      "id": "subtitle_left",
      "label": "Description (left)",
      "default": "Scopri come i nostri clienti hanno trasformato le loro case con l'aiuto di Bensa Arredamenti. Lasciati ispirare dalle loro storie."
    },
    {
      "type": "textarea",
      "id": "subtitle_right",
      "label": "Description (right)",
      "default": "Ogni progetto è unico, ogni ambiente racconta una storia. La nostra community condivide passione e risultati."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "text",
          "id": "username",
          "label": "Username",
          "info": "Social media handle (without @)."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Pick a video from your content library."
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (fallback)",
          "info": "Direct link to an mp4 file. Used only if no video is picked above."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Cover Image / Poster",
          "info": "Used as poster frame for videos or as standalone image."
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Community",
      "blocks": [
        { "type": "video_card", "settings": { "username": "bensaarredi" } },
        { "type": "video_card", "settings": { "username": "alexislconway" } },
        { "type": "video_card", "settings": { "username": "sarahdesign" } }
      ]
    }
  ]
}
{% endschema %}
