{{ 'section-custom-community.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="community" data-community>
  <div class="community__inner">
    <div class="community__header">
      <div class="community__title">
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="typo-section-heading community__heading">{{ section.settings.heading | remove: '<p>' | remove: '</p>' }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="community__cta">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="community__carousel-wrap">

    <div class="community__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'reel' -%}
            <article class="community__card community__card--reel" data-community-reel {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank or block.settings.video_url != blank -%}
                <video
                  class="community__reel-video"
                  playsinline
                  muted
                  loop
                  preload="metadata"
                  {%- if block.settings.poster != blank %} poster="{{ block.settings.poster | image_url: width: 720 }}"{% endif -%}
                  data-community-reel-video
                >
                  {%- if block.settings.video != blank -%}
                    {%- for src in block.settings.video.sources -%}
                      <source src="{{ src.url }}" type="{{ src.mime_type }}">
                    {%- endfor -%}
                  {%- elsif block.settings.video_url != blank -%}
                    <source src="{{ block.settings.video_url }}" type="video/mp4">
                  {%- endif -%}
                </video>
              {%- elsif block.settings.poster != blank -%}
                {{ block.settings.poster | image_url: width: 720 | image_tag: class: 'community__reel-img', loading: 'lazy' }}
              {%- else -%}
                <div class="community__reel-placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {%- endif -%}

              <div class="community__reel-top">
                <button type="button" class="community__reel-mute" data-community-reel-mute aria-label="Mute/Unmute">
                  <svg class="community__reel-icon-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><line x1="11" y1="5" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="15" y1="5" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  <svg class="community__reel-icon-unmuted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><path d="M11 5.5C11.8 6.3 12.25 7.4 12.25 8.5C12.25 9.6 11.8 10.7 11 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 3.5C14.3 4.8 15 6.6 15 8.5C15 10.4 14.3 12.2 13 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
              </div>

              <div class="community__reel-overlay">
                {%- if block.settings.caption != blank -%}
                  <span class="community__reel-caption">{{ block.settings.caption }}</span>
                {%- endif -%}
                <button type="button" class="community__reel-playbtn" data-community-reel-toggle aria-label="Play/Pause">
                  <svg class="community__reel-icon-play" width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M4 2.5L13 8L4 13.5V2.5Z" fill="currentColor"/></svg>
                  <svg class="community__reel-icon-pause" width="18" height="18" viewBox="0 0 16 16" fill="none"><rect x="3" y="2" width="4" height="12" rx="1" fill="currentColor"/><rect x="9" y="2" width="4" height="12" rx="1" fill="currentColor"/></svg>
                </button>
              </div>
            </article>

        {%- endcase -%}
      {%- endfor -%}
    </div>

      <button type="button" class="community__nav-btn community__nav-btn--prev" data-community-prev aria-label="Precedente" disabled>
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button type="button" class="community__nav-btn community__nav-btn--next" data-community-next aria-label="Successivo">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
(function(){
  var root = document.currentScript.closest('[data-community]') || document.querySelector('[data-community]');
  if (!root) return;

  var reels = root.querySelectorAll('[data-community-reel]');
  if (!reels.length) return;

  var ioSupported = 'IntersectionObserver' in window;
  var observer = null;

  if (ioSupported) {
    observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var vid = entry.target.querySelector('[data-community-reel-video]');
        if (!vid) return;
        if (entry.isIntersecting) {
          vid.play().catch(function(){});
        } else {
          vid.pause();
        }
      });
    }, { threshold: 0.4 });
  }

  reels.forEach(function(reel) {
    var vid = reel.querySelector('[data-community-reel-video]');
    var toggle = reel.querySelector('[data-community-reel-toggle]');
    var muteBtn = reel.querySelector('[data-community-reel-mute]');

    if (vid && observer) observer.observe(reel);

    if (muteBtn && vid) {
      muteBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        vid.muted = !vid.muted;
        reel.classList.toggle('is-unmuted', !vid.muted);
      });
    }

    if (toggle && vid) {
      toggle.addEventListener('click', function(e) {
        e.stopPropagation();
        if (vid.paused) {
          vid.play().catch(function(){});
          reel.classList.add('is-playing');
        } else {
          vid.pause();
          reel.classList.remove('is-playing');
        }
      });

      vid.addEventListener('play', function() { reel.classList.add('is-playing'); });
      vid.addEventListener('pause', function() { reel.classList.remove('is-playing'); });
    }

    if (vid) {
      reel.addEventListener('click', function() {
        if (vid.paused) {
          vid.play().catch(function(){});
        } else {
          vid.pause();
        }
      });
    }
  });

  /* ── Carousel arrows ── */
  var carousel = root.querySelector('.community__grid');
  var prevBtn = root.querySelector('[data-community-prev]');
  var nextBtn = root.querySelector('[data-community-next]');

  if (carousel && prevBtn && nextBtn) {
    function getStep() {
      var card = carousel.querySelector('.community__card');
      if (!card) return 300;
      var gap = parseFloat(getComputedStyle(carousel).gap) || 20;
      return card.offsetWidth + gap;
    }

    function updateArrows() {
      var scrollLeft = carousel.scrollLeft;
      var maxScroll = carousel.scrollWidth - carousel.clientWidth;
      prevBtn.disabled = scrollLeft <= 2;
      nextBtn.disabled = scrollLeft >= maxScroll - 2;
    }

    prevBtn.addEventListener('click', function() {
      carousel.scrollBy({ left: -getStep(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', function() {
      carousel.scrollBy({ left: getStep(), behavior: 'smooth' });
    });

    carousel.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);
    updateArrows();

    /* ── Drag to scroll ── */
    var isPointerDown = false;
    var isDragging = false;
    var startX = 0;
    var scrollStart = 0;
    var DRAG_THRESHOLD = 6;

    carousel.addEventListener('mousedown', function(e) {
      if (e.button !== 0) return;
      isPointerDown = true;
      isDragging = false;
      startX = e.pageX;
      scrollStart = carousel.scrollLeft;
      carousel.style.cursor = 'grabbing';
    });

    window.addEventListener('mousemove', function(e) {
      if (!isPointerDown) return;
      var dx = e.pageX - startX;
      if (!isDragging && Math.abs(dx) > DRAG_THRESHOLD) {
        isDragging = true;
        carousel.style.scrollSnapType = 'none';
      }
      if (isDragging) {
        carousel.scrollLeft = scrollStart - dx;
        e.preventDefault();
      }
    });

    window.addEventListener('mouseup', function() {
      if (!isPointerDown) return;
      isPointerDown = false;
      if (isDragging) {
        carousel.style.scrollSnapType = 'x mandatory';
        setTimeout(function() { isDragging = false; }, 0);
      }
      carousel.style.cursor = '';
    });

    carousel.addEventListener('click', function(e) {
      if (isDragging) {
        e.preventDefault();
        e.stopPropagation();
      }
    }, true);
  }
})();
</script>

{% schema %}
{
  "name": "Community",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Pre-titolo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#1E8BA8"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>I consigli dei nostri <em>Esperti</em></p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Parla con noi"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel (video)",
      "settings": [
        { "type": "video", "id": "video", "label": "Video (vertical 9:16)" },
        { "type": "text", "id": "video_url", "label": "Video URL (external MP4)", "info": "Fallback if no Shopify video is uploaded." },
        { "type": "image_picker", "id": "poster", "label": "Poster / Thumbnail" },
        { "type": "text", "id": "caption", "label": "Caption / username", "default": "@bensaarredi" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Community",
      "blocks": [
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" },
        { "type": "reel" }
      ]
    }
  ]
}
{% endschema %}
