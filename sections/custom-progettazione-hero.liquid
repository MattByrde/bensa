{{ 'section-custom-progettazione-hero.css' | asset_url | stylesheet_tag }}

<div class="prog-hero" style="min-height: {{ section.settings.height }}vh;">

  <div class="prog-hero__media">
    {%- if section.settings.video != blank -%}
      <video
        class="prog-hero__video"
        src="{{ section.settings.video.sources[1].url | default: section.settings.video.sources[0].url }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1920 | image_tag: class: 'prog-hero__video-poster', loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
      {%- endif -%}
    {%- elsif section.settings.video_url != blank -%}
      <video
        class="prog-hero__video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '750, 1100, 1500, 1920'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="prog-hero__overlay"></div>

  <div class="prog-hero__inner">

    {%- comment -%} Left: text content {%- endcomment -%}
    <div class="prog-hero__content">
      {%- if section.settings.subtitle != blank -%}
        <span class="prog-hero__subtitle">{{ section.settings.subtitle }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="prog-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="prog-hero__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="prog-hero__btn typo-btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Right: floating reviews card {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="prog-hero__reviews" data-prog-reviews>
        <div class="prog-hero__reviews-card">

          {%- comment -%} Header: star summary + label {%- endcomment -%}
          <div class="prog-hero__reviews-header">
            <div class="prog-hero__reviews-stars">
              {%- for i in (1..5) -%}
                <svg width="15" height="15" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
              <span class="prog-hero__reviews-score">{{ section.settings.score | default: '5.0' }}</span>
              <span class="prog-hero__reviews-count">· +{{ section.blocks.size }}0 recensioni</span>
            </div>
            <span class="prog-hero__reviews-label">Recensioni</span>
          </div>

          {%- comment -%} Scrolling review items — grouped in pages of 2 {%- endcomment -%}
          <div class="prog-hero__reviews-viewport" data-prog-reviews-viewport>
            <div class="prog-hero__reviews-track" data-prog-reviews-track>
              {%- assign page_size = 2 -%}
              {%- assign total_pages = section.blocks.size | divided_by: page_size | ceil -%}
              {%- assign last_page = total_pages | minus: 1 -%}
              {%- for page_num in (0..last_page) -%}
                {%- assign start_idx = page_num | times: page_size -%}
                {%- assign end_idx = start_idx | plus: page_size | minus: 1 -%}
                <div class="prog-hero__reviews-page">
                  {%- for block in section.blocks -%}
                    {%- if forloop.index0 >= start_idx and forloop.index0 <= end_idx -%}
                      <div class="prog-hero__review-item" {{ block.shopify_attributes }}>
                        <div class="prog-hero__review-top">
                          <div class="prog-hero__review-avatar">
                            {%- if block.settings.author_image != blank -%}
                              {{ block.settings.author_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                            {%- else -%}
                              {{ block.settings.author_name | slice: 0 | upcase }}
                            {%- endif -%}
                          </div>
                          <div class="prog-hero__review-meta">
                            <span class="prog-hero__review-name">{{ block.settings.author_name }} — {{ block.settings.author_location }}</span>
                            <div class="prog-hero__review-item-stars">
                              {%- assign stars = block.settings.stars | default: 5 -%}
                              {%- for i in (1..stars) -%}
                                <svg width="12" height="12" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                              {%- endfor -%}
                            </div>
                          </div>
                        </div>
                        {%- if block.settings.review_text != blank -%}
                          <p class="prog-hero__review-text">{{ block.settings.review_text }}</p>
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endfor -%}
            </div>
          </div>

          {%- comment -%} Dots — one per page of 2 {%- endcomment -%}
          {%- assign total_pages = section.blocks.size | divided_by: 2 | ceil -%}
          <div class="prog-hero__reviews-dots" data-prog-reviews-dots>
            {%- for i in (1..total_pages) -%}
              <button class="prog-hero__reviews-dot{% if forloop.first %} is-active{% endif %}" data-prog-dot="{{ forloop.index0 }}" aria-label="Pagina {{ forloop.index }}"></button>
            {%- endfor -%}
          </div>

        </div>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function () {
    var widget = document.querySelector('[data-prog-reviews]');
    if (!widget) return;
    var track = widget.querySelector('[data-prog-reviews-track]');
    var viewport = widget.querySelector('[data-prog-reviews-viewport]');
    var dots = widget.querySelectorAll('[data-prog-dot]');
    if (!track || !dots.length) return;

    var pages = Array.from(track.children);
    var totalPages = pages.length;
    var current = 0;

    function goTo(index) {
      current = (index + totalPages) % totalPages;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';
      dots.forEach(function (d, i) {
        d.classList.toggle('is-active', i === current);
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.getAttribute('data-prog-dot')));
        resetAuto();
      });
    });

    /* ── Drag / swipe ── */
    var dragStartX = 0;
    var dragging = false;
    var dragMoved = false;

    function onDragStart(e) {
      dragging = true;
      dragMoved = false;
      dragStartX = e.pageX || e.touches[0].pageX;
      track.style.transition = 'none';
      if (viewport) viewport.style.cursor = 'grabbing';
    }

    function onDragMove(e) {
      if (!dragging) return;
      var dx = (e.pageX || e.touches[0].pageX) - dragStartX;
      if (Math.abs(dx) > 4) dragMoved = true;
      var base = -(current * 100);
      var vw = track.parentElement.offsetWidth;
      var pct = (dx / vw) * 100;
      track.style.transform = 'translateX(' + (base + pct) + '%)';
    }

    function onDragEnd(e) {
      if (!dragging) return;
      dragging = false;
      if (viewport) viewport.style.cursor = '';
      track.style.transition = '';
      var dx = (e.pageX || (e.changedTouches && e.changedTouches[0].pageX) || dragStartX) - dragStartX;
      var threshold = track.parentElement.offsetWidth * 0.2;
      if (dx < -threshold) goTo(current + 1);
      else if (dx > threshold) goTo(current - 1);
      else goTo(current);
      if (dragMoved) resetAuto();
    }

    if (viewport) {
      viewport.style.cursor = 'grab';
      viewport.addEventListener('mousedown', onDragStart);
      viewport.addEventListener('mousemove', onDragMove);
      viewport.addEventListener('mouseup', onDragEnd);
      viewport.addEventListener('mouseleave', onDragEnd);
      viewport.addEventListener('touchstart', onDragStart, { passive: true });
      viewport.addEventListener('touchmove', onDragMove, { passive: true });
      viewport.addEventListener('touchend', onDragEnd);
      viewport.addEventListener('click', function (e) {
        if (dragMoved) { e.preventDefault(); e.stopPropagation(); }
      }, true);
    }

    var timer;
    function startAuto() {
      timer = setInterval(function () { goTo(current + 1); }, 4000);
    }
    function resetAuto() { clearInterval(timer); startAuto(); }

    startAuto();
    widget.addEventListener('mouseenter', function () { clearInterval(timer); });
    widget.addEventListener('mouseleave', startAuto);
  })();
</script>

{% schema %}
{
  "name": "Progettazione Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video di sfondo",
      "info": "Se impostato, ha priorità sull'immagine."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "URL video esterno (.mp4)",
      "info": "Alternativa al video Shopify. Incolla un URL diretto a un file .mp4."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine di sfondo",
      "info": "Usata come fallback se nessun video è impostato, o come poster del video."
    },
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 75
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sottotitolo",
      "default": "Progettazione"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Progettiamo il tuo spazio ideale"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Testo introduttivo",
      "default": "All'ingresso nel nostro showroom sarete accolti da personale esperto, pronto ad ascoltare con attenzione le vostre esigenze e i vostri desideri."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo pulsante",
      "default": "Contattaci"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link pulsante"
    },
    {
      "type": "text",
      "id": "score",
      "label": "Punteggio medio",
      "default": "5.0"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Recensione",
      "settings": [
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Foto autore"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Nome autore",
          "default": "Maria Rossi"
        },
        {
          "type": "text",
          "id": "author_location",
          "label": "Città",
          "default": "Cuneo"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stelle",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Testo recensione",
          "default": "Qualità eccezionale e un servizio clienti impeccabile. Non potremmo essere più soddisfatti!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Progettazione Hero",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author_name": "Maria Rossi",
            "author_location": "Cuneo",
            "stars": 5,
            "review_text": "Qualità eccezionale e un servizio clienti impeccabile. Il team ha ascoltato ogni nostra richiesta con grande attenzione."
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Luca Bianchi",
            "author_location": "Torino",
            "stars": 5,
            "review_text": "Progettazione curata nei minimi dettagli. Dalla prima consulenza alla consegna, tutto perfetto."
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Giulia Verdi",
            "author_location": "Alba",
            "stars": 5,
            "review_text": "Finalmente la casa che sognavo. Materiali di prima qualità e un'atmosfera che rispecchia esattamente la nostra personalità."
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Roberto Ferrari",
            "author_location": "Vignolo",
            "stars": 5,
            "review_text": "Professionalità e competenza al massimo livello. Il rendering 3D ci ha permesso di vedere il risultato finale ancora prima dell'installazione."
          }
        }
      ]
    }
  ]
}
{% endschema %}
