{{ 'section-custom-progettazione-hero.css' | asset_url | stylesheet_tag: preload: true }}

<div class="prog-hero" data-prog-hero style="--prog-hero-h: {{ section.settings.height }}vh; --prog-hero-h-mobile: {{ section.settings.height_mobile }}vh;">

  {%- comment -%} Background: video (section-level, persists across slides) or image fallback per slide {%- endcomment -%}
  <div class="prog-hero__media">
    {%- if section.settings.video != blank -%}
      <video
        class="prog-hero__video"
        src="{{ section.settings.video.sources[1].url | default: section.settings.video.sources[0].url }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1920 | image_tag: class: 'prog-hero__video-poster', loading: 'eager', fetchpriority: 'high', sizes: '100vw' }}
      {%- endif -%}
    {%- elsif section.settings.video_url != blank -%}
      <video
        class="prog-hero__video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
      ></video>
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '100vw',
        widths: '750, 1100, 1500, 1920'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="prog-hero__overlay"></div>

  {%- comment -%} Slides {%- endcomment -%}
  <div class="prog-hero__slides" data-prog-slides>
    {%- for block in section.blocks -%}
      <div class="prog-hero__slide{% if forloop.first %} is-active{% endif %}" data-prog-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>

        {%- comment -%} Optional per-slide image override (fades over the background video) {%- endcomment -%}
        {%- if block.settings.slide_image != blank -%}
          <div class="prog-hero__slide-image">
            {{ block.settings.slide_image | image_url: width: 1920 | image_tag:
              loading: 'lazy',
              sizes: '100vw',
              widths: '750, 1100, 1500, 1920'
            }}
          </div>
        {%- endif -%}

        <div class="prog-hero__inner">
          <div class="prog-hero__content">
            {%- if block.settings.tags != blank -%}
              <div class="prog-hero__tags">
                {%- assign tag_list = block.settings.tags | split: ',' -%}
                {%- for t in tag_list -%}
                  <span class="prog-hero__tag">{{ t | strip }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if block.settings.eyebrow != blank -%}
              <span class="prog-hero__eyebrow">{{ block.settings.eyebrow }}</span>
            {%- endif -%}

            {%- if block.settings.heading != blank -%}
              {%- if forloop.first -%}
                <h1 class="prog-hero__heading">{{ block.settings.heading }}</h1>
              {%- else -%}
                <h2 class="prog-hero__heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
            {%- endif -%}

            {%- if block.settings.subtext != blank -%}
              <p class="prog-hero__subtext">{{ block.settings.subtext }}</p>
            {%- endif -%}

            <div class="prog-hero__actions">
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link | default: '#' }}" class="prog-hero__btn prog-hero__btn--primary typo-btn">
                  {{ block.settings.button_label }}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a href="{{ block.settings.button_link_2 | default: '#' }}" class="prog-hero__btn prog-hero__btn--secondary typo-btn">
                  {{ block.settings.button_label_2 }}
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>

      </div>
    {%- endfor -%}
  </div>

  {%- assign slide_count = section.blocks.size -%}
  {%- if slide_count > 1 -%}
    <div class="prog-hero__controls" data-prog-controls>
      <div class="prog-hero__counter">
        <span data-prog-current>01</span>
        <span class="prog-hero__counter-sep">/</span>
        <span>{{ slide_count | prepend: '00' | slice: -2, 2 }}</span>
      </div>
      <div class="prog-hero__progress" data-prog-progress>
        <div class="prog-hero__progress-bar" data-prog-bar></div>
      </div>
      <div class="prog-hero__arrows">
        <button class="prog-hero__arrow prog-hero__arrow--prev" data-prog-prev aria-label="Slide precedente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l6-6M5 12l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="prog-hero__arrow prog-hero__arrow--next" data-prog-next aria-label="Slide successiva">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M19 12l-6-6M19 12l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  {%- endif -%}

  <a href="#prog-hero-next" class="prog-hero__scroll" aria-label="Scorri giù">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>

</div>
<span id="prog-hero-next"></span>

<script>
  (function () {
    var hero = document.querySelector('[data-prog-hero]');
    if (!hero) return;

    var slides = hero.querySelectorAll('[data-prog-slide]');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;
    var autoDelay = 6000;
    var timer;
    var counterEl = hero.querySelector('[data-prog-current]');
    var barEl = hero.querySelector('[data-prog-bar]');

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function goTo(idx) {
      slides[current].classList.remove('is-active');
      current = ((idx % total) + total) % total;
      slides[current].classList.add('is-active');
      if (counterEl) counterEl.textContent = pad(current + 1);
      restartBar();
    }

    function restartBar() {
      if (!barEl) return;
      barEl.style.transition = 'none';
      barEl.style.width = '0%';
      barEl.offsetWidth;
      barEl.style.transition = 'width ' + autoDelay + 'ms linear';
      barEl.style.width = '100%';
    }

    function startAuto() {
      restartBar();
      timer = setInterval(function () { goTo(current + 1); }, autoDelay);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    var prevBtn = hero.querySelector('[data-prog-prev]');
    var nextBtn = hero.querySelector('[data-prog-next]');

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); resetAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); resetAuto(); });

    var startX = 0;
    var dragging = false;

    hero.addEventListener('touchstart', function (e) {
      startX = e.touches[0].clientX;
      dragging = true;
    }, { passive: true });

    hero.addEventListener('touchend', function (e) {
      if (!dragging) return;
      dragging = false;
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 50) { goTo(dx < 0 ? current + 1 : current - 1); resetAuto(); }
    });

    startAuto();
  })();
</script>

{% schema %}
{
  "name": "Progettazione Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Sfondo sezione"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video di sfondo",
      "info": "Se impostato, ha priorità sull'immagine e persiste su tutte le slide."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "URL video esterno (.mp4)",
      "info": "Alternativa al video Shopify. Incolla un URL diretto a un file .mp4."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine di sfondo",
      "info": "Fallback se nessun video è impostato, o poster del video."
    },
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione (desktop)",
      "min": 30,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Altezza sezione (mobile)",
      "min": 30,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 70
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "slide_image",
          "label": "Immagine slide (opzionale)",
          "info": "Se impostata, sovrascrive il video/immagine di sezione solo per questa slide."
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tag",
          "info": "Separa più tag con una virgola. Es: Residenziale, Villa, Cherasco"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow (piccolo testo sopra il titolo)",
          "default": "Progettazione d'interni"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Titolo",
          "default": "Progettiamo il tuo spazio ideale"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Testo introduttivo",
          "default": "Dal primo sopralluogo alla consegna, un solo interlocutore e un capitolato scritto."
        },
        {
          "type": "header",
          "content": "Pulsante primario"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Testo pulsante",
          "default": "Contattaci"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link pulsante"
        },
        {
          "type": "header",
          "content": "Pulsante secondario"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Testo pulsante"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Link pulsante"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Progettazione Hero",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Progettazione d'interni",
            "heading": "Progettiamo il tuo spazio ideale",
            "subtext": "Dal primo sopralluogo alla consegna, un solo interlocutore e un capitolato scritto.",
            "tags": "Residenziale, Chiavi in mano",
            "button_label": "Contattaci",
            "button_label_2": "Scopri il metodo"
          }
        },
        {
          "type": "slide",
          "settings": {
            "eyebrow": "Studio dal 1983",
            "heading": "Case che invecchiano bene",
