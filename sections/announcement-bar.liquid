{%- comment -%} Announcement Bar — Luxury B2B focus {%- endcomment -%}

<div class="announcement-bar" data-section-id="{{ section.id }}">
  <div class="announcement-bar__inner">
    <div class="announcement-bar__left">
      {%- if section.settings.text_left != blank -%}
        {%- if section.settings.link_left != blank -%}
          <a href="{{ section.settings.link_left }}" class="announcement-bar__cta">
            {{ section.settings.text_left }}
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        {%- else -%}
          <span class="announcement-bar__item">{{ section.settings.text_left }}</span>
        {%- endif -%}
      {%- endif -%}

      <span class="announcement-bar__separator"></span>

      {%- if section.settings.text_center != blank -%}
        <span class="announcement-bar__item">{{ section.settings.text_center }}</span>
      {%- endif -%}
    </div>

    {%- if section.settings.btn_label != blank -%}
      <a href="{{ section.settings.btn_link | default: '#' }}" class="announcement-bar__btn">
        {{ section.settings.btn_label }}
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "class": "section-announcement",
  "settings": [
    {
      "type": "text",
      "id": "text_left",
      "label": "Left text (CTA)",
      "default": "Sei un architetto? Collabora con noi"
    },
    {
      "type": "url",
      "id": "link_left",
      "label": "Left link"
    },
    {
      "type": "text",
      "id": "text_center",
      "label": "Center text",
      "default": "Progettazione completa d'interni"
    },
    {
      "type": "header",
      "content": "Right button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button label",
      "default": "Diventa partner"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
