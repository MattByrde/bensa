{%- comment -%} Announcement Bar Section {%- endcomment -%}

{%- if section.settings.text != blank -%}
  <div class="announcement-bar" data-section-id="{{ section.id }}">
    <div class="announcement-bar__marquee">
      {%- for i in (1..12) -%}
        <span class="announcement-bar__item">
          {%- if section.settings.link != blank -%}
            <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
          {%- else -%}
            {{ section.settings.text }}
          {%- endif -%}
        </span>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "class": "section-announcement",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over $500"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
