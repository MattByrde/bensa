{{ 'section-custom-marchi-hero.css' | asset_url | stylesheet_tag }}

<div class="marchi-hero" data-marchi-hero style="min-height: {{ section.settings.height }}vh;">

  <div class="marchi-hero__slides" data-marchi-slides>
    {%- for block in section.blocks -%}
      <div class="marchi-hero__slide{% if forloop.first %} is-active{% endif %}" data-marchi-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>

        <div class="marchi-hero__media">
          {%- if block.settings.image != blank -%}
            {%- if forloop.first -%}
              {{ block.settings.image | image_url: width: 1920 | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', widths: '750, 1100, 1500, 1920' }}
            {%- else -%}
              {{ block.settings.image | image_url: width: 1920 | image_tag: loading: 'lazy', sizes: '100vw', widths: '750, 1100, 1500, 1920' }}
            {%- endif -%}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>

        <div class="marchi-hero__overlay"></div>

        <div class="marchi-hero__inner">
          <div class="marchi-hero__content">
            {%- if block.settings.tags != blank -%}
              <div class="marchi-hero__tags">
                {%- assign tag_list = block.settings.tags | split: ',' -%}
                {%- for t in tag_list -%}
                  <span class="marchi-hero__tag">{{ t | strip }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
            {%- if block.settings.brand_name != blank -%}
              <h2 class="marchi-hero__heading">{{ block.settings.brand_name }}</h2>
            {%- endif -%}
            {%- if block.settings.logo != blank -%}
              <div class="marchi-hero__logo">
                {{ block.settings.logo | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.brand_name }}
              </div>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="marchi-hero__subtext">{{ block.settings.description }}</p>
            {%- endif -%}
            <div class="marchi-hero__actions">
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.button_link | default: '#' }}" class="marchi-hero__btn marchi-hero__btn--primary typo-btn">
                  {{ block.settings.button_label }}
                </a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a href="{{ block.settings.button_link_2 | default: '#' }}" class="marchi-hero__btn marchi-hero__btn--secondary typo-btn">
                  {{ block.settings.button_label_2 }}
                  <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>

      </div>
    {%- endfor -%}
  </div>

  {%- assign slide_count = section.blocks.size -%}
  {%- if slide_count > 1 -%}
    <div class="marchi-hero__controls" data-marchi-controls>
      <div class="marchi-hero__counter">
        <span data-marchi-current>01</span>
        <span class="marchi-hero__counter-sep">/</span>
        <span>{{ slide_count | prepend: '00' | slice: -2, 2 }}</span>
      </div>
      <div class="marchi-hero__progress" data-marchi-progress>
        <div class="marchi-hero__progress-bar" data-marchi-bar></div>
      </div>
      <div class="marchi-hero__arrows">
        <button class="marchi-hero__arrow marchi-hero__arrow--prev" data-marchi-prev aria-label="Slide precedente">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M19 12H5M5 12l6-6M5 12l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="marchi-hero__arrow marchi-hero__arrow--next" data-marchi-next aria-label="Slide successiva">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M19 12l-6-6M19 12l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  {%- endif -%}

  <a href="#marchi-hero-next" class="marchi-hero__scroll" aria-label="Scorri giù">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>

</div>
<span id="marchi-hero-next"></span>

<script>
  (function () {
    var hero = document.querySelector('[data-marchi-hero]');
    if (!hero) return;

    var slides = hero.querySelectorAll('[data-marchi-slide]');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;
    var autoDelay = 6000;
    var timer;
    var counterEl = hero.querySelector('[data-marchi-current]');
    var barEl = hero.querySelector('[data-marchi-bar]');

    function pad(n) { return n < 10 ? '0' + n : '' + n; }

    function goTo(idx) {
      slides[current].classList.remove('is-active');
      current = ((idx % total) + total) % total;
      slides[current].classList.add('is-active');
      if (counterEl) counterEl.textContent = pad(current + 1);
      restartBar();
    }

    function restartBar() {
      if (!barEl) return;
      barEl.style.transition = 'none';
      barEl.style.width = '0%';
      barEl.offsetWidth;
      barEl.style.transition = 'width ' + autoDelay + 'ms linear';
      barEl.style.width = '100%';
    }

    function startAuto() {
      restartBar();
      timer = setInterval(function () { goTo(current + 1); }, autoDelay);
    }

    function resetAuto() {
      clearInterval(timer);
      startAuto();
    }

    var prevBtn = hero.querySelector('[data-marchi-prev]');
    var nextBtn = hero.querySelector('[data-marchi-next]');

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(current - 1); resetAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(current + 1); resetAuto(); });

    var startX = 0;
    var dragging = false;

    hero.addEventListener('touchstart', function (e) {
      startX = e.touches[0].clientX;
      dragging = true;
    }, { passive: true });

    hero.addEventListener('touchend', function (e) {
      if (!dragging) return;
      dragging = false;
      var dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 50) { goTo(dx < 0 ? current + 1 : current - 1); resetAuto(); }
    });

    startAuto();
  })();
</script>

{% schema %}
{
  "name": "Marchi Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "brand_card",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine sfondo"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo brand"
        },
        {
          "type": "text",
          "id": "tags",
          "label": "Tag",
          "info": "Separa più tag con una virgola. Es: Cucine, Bagni, Living"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Nome brand"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrizione"
        },
        {
          "type": "header",
          "content": "Pulsante primario"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Testo pulsante"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link pulsante"
        },
        {
          "type": "header",
          "content": "Pulsante secondario"
        },
        {
          "type": "text",
          "id": "button_label_2",
          "label": "Testo pulsante"
        },
        {
          "type": "url",
          "id": "button_link_2",
          "label": "Link pulsante"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marchi Hero",
      "blocks": [
        { "type": "brand_card" },
        { "type": "brand_card" },
        { "type": "brand_card" }
      ]
    }
  ]
}
{% endschema %}
