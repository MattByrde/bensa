{{ 'section-custom-about-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: 0;
    padding-bottom: 0;
  }
{%- endstyle -%}

<section class="about-hero" data-about-carousel style="min-height: {{ section.settings.height }}vh;">
  <div class="about-hero__scroller" data-about-scroller>
    <div class="about-hero__track" data-about-track>
      {%- for block in section.blocks -%}
        <article class="about-hero__slide" {{ block.shopify_attributes }}>
          <div class="about-hero__media">
            {%- if block.settings.image != blank -%}
              {%- if forloop.first -%}
                {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', fetchpriority: 'high', widths: '750, 1100, 1500, 2000' }}
              {%- else -%}
                {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '750, 1100, 1500, 2000' }}
              {%- endif -%}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>

          <div class="about-hero__overlay"></div>

          <div class="about-hero__inner">
            <div class="about-hero__content">
              {%- if section.settings.kicker != blank -%}
                <span class="about-hero__kicker">{{ section.settings.kicker }}</span>
              {%- endif -%}

              <div class="about-hero__stars" aria-label="Rating">
                {%- assign stars = block.settings.stars | default: 5 -%}
                {%- for i in (1..5) -%}
                  <svg class="about-hero__star {% if i <= stars %}about-hero__star--filled{% endif %}" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {%- endfor -%}
              </div>

              {%- if block.settings.review_text != blank -%}
                <p class="about-hero__quote">"{{ block.settings.review_text }}"</p>
              {%- endif -%}

              <div class="about-hero__author">
                {%- if block.settings.author_image != blank -%}
                  <div class="about-hero__author-img">
                    {{ block.settings.author_image | image_url: width: 96 | image_tag: loading: 'lazy', alt: block.settings.author_name }}
                  </div>
                {%- endif -%}
                <div class="about-hero__author-info">
                  {%- if block.settings.author_name != blank -%}
                    <span class="about-hero__author-name">{{ block.settings.author_name }}</span>
                  {%- endif -%}
                  {%- if block.settings.author_role != blank -%}
                    <span class="about-hero__author-role">{{ block.settings.author_role }}</span>
                  {%- endif -%}
                </div>
                {%- if block.settings.tag != blank -%}
                  <span class="about-hero__tag">{{ block.settings.tag }}</span>
                {%- endif -%}
              </div>

              {%- if section.settings.cta_label != blank -%}
                <a href="{{ section.settings.cta_link | default: '#' }}" class="about-hero__cta">
                  {{ section.settings.cta_label }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Controls (bottom-right, matching home hero) {%- endcomment -%}
  <div class="about-hero__controls">
    <div class="about-hero__dots" data-about-dots>
      {%- for block in section.blocks -%}
        <button class="about-hero__dot{% if forloop.first %} is-active{% endif %}" data-dot-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>

    <div class="about-hero__nav">
      <button class="about-hero__nav-btn" data-about-prev aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="about-hero__nav-btn" data-about-next aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('[data-about-carousel]').forEach(function (carousel) {
      var scroller = carousel.querySelector('[data-about-scroller]');
      var track = carousel.querySelector('[data-about-track]');
      if (!scroller || !track || track.children.length < 2) return;

      var origCards = Array.from(track.children);
      var n = origCards.length;

      /* ── Infinite loop: clone before + after ── */
      origCards.forEach(function (c) {
        track.appendChild(c.cloneNode(true));
      });
      origCards.forEach(function (c) {
        track.insertBefore(c.cloneNode(true), track.firstChild);
      });

      var gap = parseFloat(getComputedStyle(track).gap) || 0;

      function cardW() {
        return track.children[0].offsetWidth + gap;
      }

      function jumpToMiddle(instant) {
        var w = cardW();
        if (instant) {
          scroller.style.scrollBehavior = 'auto';
          scroller.scrollLeft = w * n;
          scroller.style.scrollBehavior = '';
        }
      }

      requestAnimationFrame(function () { requestAnimationFrame(function () { jumpToMiddle(true); updateDots(); }); });

      var ticking = false;
      scroller.addEventListener('scroll', function () {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          ticking = false;
          var w = cardW();
          var sl = scroller.scrollLeft;
          var total = w * n;
          if (sl < w * 0.5) {
            scroller.style.scrollBehavior = 'auto';
            scroller.scrollLeft = sl + total;
            scroller.style.scrollBehavior = '';
          } else if (sl >= w * (n * 2 - 0.5)) {
            scroller.style.scrollBehavior = 'auto';
            scroller.scrollLeft = sl - total;
            scroller.style.scrollBehavior = '';
          }
          updateDots();
        });
      });

      /* ── Dots ── */
      var dots = carousel.querySelectorAll('[data-dot-index]');

      function updateDots() {
        var w = cardW();
        if (!w) return;
        var idx = Math.round(scroller.scrollLeft / w) % n;
        if (idx < 0) idx += n;
        dots.forEach(function (d, i) {
          d.classList.toggle('is-active', i === idx);
        });
      }

      dots.forEach(function (dot) {
        dot.addEventListener('click', function () {
          stopAuto();
          var idx = parseInt(dot.dataset.dotIndex, 10);
          var w = cardW();
          scroller.scrollTo({ left: w * (n + idx), behavior: 'smooth' });
          setTimeout(startAuto, 4000);
        });
      });

      /* ── Drag / swipe ── */
      var isDragging = false;
      var startX = 0;
      var scrollStart = 0;
      var velocity = 0;
      var lastX = 0;
      var lastTime = 0;

      function onPointerDown(e) {
        isDragging = true;
        startX = e.pageX || e.touches[0].pageX;
        scrollStart = scroller.scrollLeft;
        lastX = startX;
        lastTime = Date.now();
        velocity = 0;
        scroller.style.scrollSnapType = 'none';
        scroller.style.cursor = 'grabbing';
        scroller.classList.add('is-dragging');
      }

      function onPointerMove(e) {
        if (!isDragging) return;
        e.preventDefault();
        var x = e.pageX || e.touches[0].pageX;
        var now = Date.now();
        var dt = now - lastTime;
        if (dt > 0) velocity = (lastX - x) / dt;
        lastX = x;
        lastTime = now;
        scroller.scrollLeft = scrollStart - (x - startX);
      }

      function onPointerUp() {
        if (!isDragging) return;
        isDragging = false;
        scroller.style.cursor = '';
        scroller.classList.remove('is-dragging');
        var w = cardW();
        var momentum = velocity * 300;
        var target = Math.round((scroller.scrollLeft + momentum) / w) * w;
        scroller.style.scrollSnapType = '';
        scroller.scrollTo({ left: target, behavior: 'smooth' });
      }

      scroller.addEventListener('mousedown', onPointerDown);
      scroller.addEventListener('mousemove', onPointerMove);
      scroller.addEventListener('mouseup', onPointerUp);
      scroller.addEventListener('mouseleave', onPointerUp);
      scroller.addEventListener('touchstart', onPointerDown, { passive: true });
      scroller.addEventListener('touchmove', onPointerMove, { passive: false });
      scroller.addEventListener('touchend', onPointerUp);

      scroller.addEventListener('click', function (e) {
        if (Math.abs(lastX - startX) > 5) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);

      /* ── Arrows ── */
      var prevBtn = carousel.querySelector('[data-about-prev]');
      var nextBtn = carousel.querySelector('[data-about-next]');
      if (prevBtn) {
        prevBtn.addEventListener('click', function () {
          stopAuto();
          scroller.scrollBy({ left: -cardW(), behavior: 'smooth' });
          setTimeout(startAuto, 4000);
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          stopAuto();
          scroller.scrollBy({ left: cardW(), behavior: 'smooth' });
          setTimeout(startAuto, 4000);
        });
      }

      /* ── Auto-play ── */
      var autoInterval = null;
      function startAuto() {
        stopAuto();
        autoInterval = setInterval(function () {
          scroller.scrollBy({ left: cardW(), behavior: 'smooth' });
        }, 7000);
      }
      function stopAuto() {
        if (autoInterval) { clearInterval(autoInterval); autoInterval = null; }
      }

      startAuto();
      carousel.addEventListener('mouseenter', stopAuto);
      carousel.addEventListener('mouseleave', startAuto);
      scroller.addEventListener('touchstart', stopAuto, { passive: true });
      scroller.addEventListener('touchend', function () { setTimeout(startAuto, 4000); });
    });
  })();
</script>

{% schema %}
{
  "name": "Chi Siamo Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Colore sfondo",
      "default": "#000"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (sopra il titolo)",
      "default": "TESTIMONIANZE"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Prenota una consulenza"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "range",
      "id": "height",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Altezza",
      "default": 90
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Recensione",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine sfondo"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stelle",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag (es. Cucine, Soggiorni)",
          "info": "Etichetta pill mostrata accanto all'autore."
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Testo recensione",
          "default": "Qualità eccezionale e un servizio clienti impeccabile. Non potremmo essere più soddisfatti."
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Foto autore"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Nome autore",
          "default": "Maria Rossi"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "Ruolo / Città",
          "default": "Milano"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Chi Siamo Hero",
      "blocks": [
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" }
      ]
    }
  ]
}
{% endschema %}
