<link rel="stylesheet" href="{{ 'section-custom-favourites-grid.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-favourites-grid.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="fav-grid page-width">
  <div class="fav-grid__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="fav-grid__heading typo-h1">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="fav-grid__description typo-body">{{ section.settings.description }}</p>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="fav-grid__grid">
      {%- for block in section.blocks -%}
        <div class="fav-grid__item fav-grid__item--{{ forloop.index }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              class="fav-grid__img"
              src="{{ block.settings.image | image_url: width: 800 }}"
              srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w, {{ block.settings.image | image_url: width: 800 }} 800w"
              sizes="(max-width: 749px) 50vw, 25vw"
              alt="{{ block.settings.image.alt | escape | default: section.settings.heading }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            <div class="fav-grid__placeholder"></div>
          {%- endif -%}

          {%- assign link_url = block.settings.link | default: '#' -%}
          {%- if block.settings.product != blank -%}
            {%- assign link_url = block.settings.product.url -%}
          {%- endif -%}
          <a href="{{ link_url }}" class="fav-grid__btn" aria-label="Shop now">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Favourites Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The people's favourite beds"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "We've sold over 150,000 beds — so when you join us, you're in great (and well-rested) company. Every day, more people discover how better nights lead to better days."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2C4A0"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "image_card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Link this card to a product."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link",
          "info": "Used only if no product is selected."
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Favourites Grid",
      "blocks": [
        { "type": "image_card" },
        { "type": "image_card" },
        { "type": "image_card" },
        { "type": "image_card" },
        { "type": "image_card" }
      ]
    }
  ]
}
{% endschema %}
