<link rel="stylesheet" href="{{ 'section-custom-ristrutturazioni-viral.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-ristrutturazioni-viral.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="ristr-viral">
  <div class="ristr-viral__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="section-heading ristr-viral__heading typo-h2">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="ristr-viral__nav" data-ristr-viral-nav>
      <button class="ristr-viral__arrow ristr-viral__arrow--prev" data-ristr-viral-prev aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="ristr-viral__arrow ristr-viral__arrow--next" data-ristr-viral-next aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="ristr-viral__carousel" data-ristr-viral-carousel data-total="{{ section.blocks.size }}">
      <div class="ristr-viral__track" data-ristr-viral-track>
        {%- for block in section.blocks -%}
          <div class="ristr-viral__card" data-ristr-viral-card {{ block.shopify_attributes }}>
            <div class="ristr-viral__card-inner">
              {%- if block.settings.video != blank -%}
                {%- assign vid_src = block.settings.video.sources | where: "mime_type", "video/mp4" | first -%}
                {%- if vid_src -%}
                  <video
                    class="ristr-viral__media"
                    src="{{ vid_src.url }}"
                    poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 }}{%- endif -%}"
                    loop
                    muted
                    playsinline
                    preload="metadata"
                    autoplay
                    data-ristr-viral-video
                  ></video>
                  <button class="ristr-viral__mute-btn" data-ristr-viral-mute aria-label="Mute / Unmute">
                    <svg class="ristr-viral__icon-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><line x1="11" y1="5" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="15" y1="5" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    <svg class="ristr-viral__icon-unmuted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><path d="M11 5.5C11.8 6.3 12.25 7.4 12.25 8.5C12.25 9.6 11.8 10.7 11 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 3.5C14.3 4.8 15 6.6 15 8.5C15 10.4 14.3 12.2 13 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                {%- endif -%}
              {%- elsif block.settings.video_url != blank -%}
                <video
                  class="ristr-viral__media"
                  src="{{ block.settings.video_url }}"
                  poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 600 }}{%- endif -%}"
                  loop
                  muted
                  playsinline
                  preload="metadata"
                  autoplay
                  data-ristr-viral-video
                ></video>
                <button class="ristr-viral__mute-btn" data-ristr-viral-mute aria-label="Mute / Unmute">
                  <svg class="ristr-viral__icon-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><line x1="11" y1="5" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="15" y1="5" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  <svg class="ristr-viral__icon-unmuted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><path d="M11 5.5C11.8 6.3 12.25 7.4 12.25 8.5C12.25 9.6 11.8 10.7 11 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 3.5C14.3 4.8 15 6.6 15 8.5C15 10.4 14.3 12.2 13 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </button>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: class: 'ristr-viral__media', loading: 'lazy' }}
              {%- else -%}
                <div class="ristr-viral__placeholder">
                  <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect width="48" height="48" rx="8" fill="#e5e0da"/><path d="M20 16L32 24L20 32V16Z" fill="#999"/></svg>
                </div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <span class="ristr-viral__card-title">{{ block.settings.title }}</span>
              {%- endif -%}

              {%- if block.settings.product != blank -%}
                {%- assign p = block.settings.product -%}
                <a href="{{ p.url }}" class="ristr-viral__product">
                  {%- if p.featured_image != blank -%}
                    <div class="ristr-viral__product-img">
                      {{ p.featured_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
                    </div>
                  {%- endif -%}
                  <div class="ristr-viral__product-info">
                    <span class="ristr-viral__product-title typo-h4">{{ p.title }}</span>
                    <span class="ristr-viral__product-price typo-caption">{{ p.price | money }}</span>
                  </div>
                </a>
              {%- elsif block.settings.product_title != blank -%}
                <div class="ristr-viral__product">
                  {%- if block.settings.product_image != blank -%}
                    <div class="ristr-viral__product-img">
                      {{ block.settings.product_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
                    </div>
                  {%- endif -%}
                  <div class="ristr-viral__product-info">
                    <span class="ristr-viral__product-title typo-h4">{{ block.settings.product_title }}</span>
                    {%- if block.settings.product_price != blank -%}
                      <span class="ristr-viral__product-price typo-caption">{{ block.settings.product_price }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

  {%- endif -%}
</div>

<script>
  (function () {
    document.querySelectorAll('[data-ristr-viral-carousel]').forEach(function (carousel) {
      var section = carousel.closest('.ristr-viral');
      var track = carousel.querySelector('[data-ristr-viral-track]');
      var prevBtn = section.querySelector('[data-ristr-viral-prev]');
      var nextBtn = section.querySelector('[data-ristr-viral-next]');
      var cards = Array.from(track.querySelectorAll('[data-ristr-viral-card]'));
      var total = cards.length;
      if (total < 1) return;

      var centerPos = 0;
      var animating = false;
      var currentTx = 0;

      function getTx(pos) {
        var card = cards[pos];
        if (!card) return 0;
        var tx = -(card.offsetLeft - carousel.offsetWidth / 2 + card.offsetWidth / 2);
        // Don't shift track past its left edge (avoid gap on the left)
        if (tx > 0) tx = 0;
        return tx;
      }

      function updateButtons() {
        if (prevBtn) prevBtn.disabled = (centerPos <= 0);
        if (nextBtn) nextBtn.disabled = (centerPos >= total - 1);
      }

      function playOnly(pos) {
        cards.forEach(function (c) { c.classList.remove('is-center'); });
        if (cards[pos]) cards[pos].classList.add('is-center');
        cards.forEach(function (c, i) {
          var v = c.querySelector('[data-ristr-viral-video]');
          if (!v) return;
          if (i === pos) { v.play().catch(function () {}); }
          else { v.pause(); }
        });
      }

      function setTx(tx, animated) {
        currentTx = tx;
        if (animated) {
          track.classList.add('is-sliding');
          track.style.transform = 'translateX(' + tx + 'px)';
        } else {
          track.classList.remove('is-sliding');
          track.classList.add('no-transition');
          track.style.transform = 'translateX(' + tx + 'px)';
          void track.offsetWidth;
          track.classList.remove('no-transition');
        }
      }

      function snapToCenter(animated) {
        setTx(getTx(centerPos), animated);
      }

      function goNext() {
        if (animating || centerPos >= total - 1) return;
        animating = true;
        centerPos++;
        track.classList.add('is-sliding');
        track.style.transform = 'translateX(' + getTx(centerPos) + 'px)';
        setTimeout(function () {
          track.classList.remove('is-sliding');
          playOnly(centerPos);
          currentTx = getTx(centerPos);
          animating = false;
          updateButtons();
        }, 320);
      }

      function goPrev() {
        if (animating || centerPos <= 0) return;
        animating = true;
        centerPos--;
        track.classList.add('is-sliding');
        track.style.transform = 'translateX(' + getTx(centerPos) + 'px)';
        setTimeout(function () {
          track.classList.remove('is-sliding');
          playOnly(centerPos);
          currentTx = getTx(centerPos);
          animating = false;
          updateButtons();
        }, 320);
      }

      if (prevBtn) prevBtn.addEventListener('click', goPrev);
      if (nextBtn) nextBtn.addEventListener('click', goNext);

      /* ── Mouse drag ── */
      var isDragging = false;
      var dragStartX = 0;
      var dragStartTx = 0;
      var DRAG_THRESHOLD = 50;

      carousel.addEventListener('mousedown', function (e) {
        if (e.button !== 0) return;
        isDragging = true;
        dragStartX = e.clientX;
        dragStartTx = currentTx;
        track.classList.remove('is-sliding');
        carousel.classList.add('is-dragging');
        e.preventDefault();
      });

      document.addEventListener('mousemove', function (e) {
        if (!isDragging) return;
        var delta = e.clientX - dragStartX;
        currentTx = dragStartTx + delta;
        track.style.transform = 'translateX(' + currentTx + 'px)';
      });

      document.addEventListener('mouseup', function (e) {
        if (!isDragging) return;
        isDragging = false;
        carousel.classList.remove('is-dragging');
        var delta = e.clientX - dragStartX;
        if (Math.abs(delta) > DRAG_THRESHOLD) {
          if (delta < 0) goNext();
          else goPrev();
        } else {
          snapToCenter(true);
          setTimeout(function () { track.classList.remove('is-sliding'); }, 320);
        }
      });

      /* Mute/unmute toggle */
      carousel.addEventListener('click', function (e) {
        var muteBtn = e.target.closest('[data-ristr-viral-mute]');
        if (muteBtn) {
          var inner = muteBtn.closest('.ristr-viral__card-inner');
          var video = inner.querySelector('[data-ristr-viral-video]');
          if (!video) return;
          video.muted = !video.muted;
          inner.classList.toggle('is-unmuted', !video.muted);
        }
      });

      window.addEventListener('resize', function () {
        snapToCenter(false);
      });

      /* ── Initial render ── */
      playOnly(centerPos);
      snapToCenter(false);
      updateButtons();
    });
  })();
</script>

{% schema %}
{
  "name": "Ristrutturazioni Viral",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "I nostri lavori"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Centered title overlay on the card."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload a video directly from Shopify."
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (fallback)",
          "info": "Direct link to an mp4. Used only if no video is uploaded above."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Cover Image / Poster",
          "info": "Used as poster frame for videos or as standalone image."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Select a product to show below the video."
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image (manual)",
          "info": "Only used if no product is selected above."
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Product Title (manual)",
          "info": "Only used if no product is selected above."
        },
        {
          "type": "text",
          "id": "product_price",
          "label": "Product Price (manual)",
          "info": "Only used if no product is selected above. e.g. $48"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Ristrutturazioni Viral",
      "blocks": [
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "video_card" }
      ]
    }
  ]
}
{% endschema %}
