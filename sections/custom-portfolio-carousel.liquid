{{ 'section-custom-portfolio-carousel.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="portfolio-carousel" data-portfolio-carousel>

  {%- comment -%} Scroll area with cards {%- endcomment -%}
  <div class="portfolio-carousel__scroller" data-portfolio-scroller>
    <div class="portfolio-carousel__track" data-portfolio-track>
      {%- for block in section.blocks -%}
        <div class="portfolio-carousel__card" {{ block.shopify_attributes }}>

          {%- comment -%} Background Image {%- endcomment -%}
          <div class="portfolio-carousel__media">
            {%- if block.settings.image != blank -%}
              {%- if forloop.first -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'portfolio-carousel__media-el', loading: 'eager', fetchpriority: 'high' }}
              {%- else -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'portfolio-carousel__media-el', loading: 'lazy' }}
              {%- endif -%}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'portfolio-carousel__media-el placeholder-svg' }}
            {%- endif -%}
          </div>

          {%- comment -%} Gradient Overlay {%- endcomment -%}
          <div class="portfolio-carousel__overlay"></div>

          {%- comment -%} Card Content {%- endcomment -%}
          <div class="portfolio-carousel__card-inner">
            <div class="portfolio-carousel__review-top">
              {%- comment -%} Stars {%- endcomment -%}
              <div class="portfolio-carousel__stars">
                {%- assign stars = block.settings.stars | default: 5 -%}
                {%- for i in (1..5) -%}
                  <svg class="portfolio-carousel__star {% if i <= stars %}portfolio-carousel__star--filled{% endif %}" viewBox="0 0 24 24" width="16" height="16">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {%- endfor -%}
              </div>

              {%- if block.settings.tag != blank -%}
                <span class="portfolio-carousel__tag">{{ block.settings.tag }}</span>
              {%- endif -%}
            </div>

            <div class="portfolio-carousel__review-content">
              {%- if block.settings.review_text != blank -%}
                <p class="portfolio-carousel__review-text">{{ block.settings.review_text }}</p>
              {%- endif -%}
            </div>

            {%- comment -%} Author strip {%- endcomment -%}
            <div class="portfolio-carousel__author">
              {%- if block.settings.author_image != blank -%}
                <div class="portfolio-carousel__author-img">
                  {{ block.settings.author_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                </div>
              {%- endif -%}
              <div class="portfolio-carousel__author-info">
                {%- if block.settings.author_name != blank -%}
                  <span class="portfolio-carousel__author-name typo-h4">{{ block.settings.author_name }}</span>
                {%- endif -%}
                {%- if block.settings.author_role != blank -%}
                  <span class="portfolio-carousel__author-role typo-caption">{{ block.settings.author_role }}</span>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Floating next arrow {%- endcomment -%}
  <button class="portfolio-carousel__next-float" data-portfolio-next aria-label="Next">
    <svg width="22" height="22" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  {%- comment -%} Dot Indicators {%- endcomment -%}
  <div class="portfolio-carousel__dots" data-portfolio-dots>
    {%- for block in section.blocks -%}
      <button class="portfolio-carousel__dot{% if forloop.first %} is-active{% endif %}" data-dot-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
    {%- endfor -%}
  </div>
</div>

<script>
  (function () {
    document.querySelectorAll('[data-portfolio-carousel]').forEach(function (carousel) {
      var scroller = carousel.querySelector('[data-portfolio-scroller]');
      var track = carousel.querySelector('[data-portfolio-track]');
      if (!scroller || !track || track.children.length < 2) return;

      var origCards = Array.from(track.children);
      var n = origCards.length;

      /* ── Infinite loop: clone before + after ── */
      origCards.forEach(function (c) {
        track.appendChild(c.cloneNode(true));
      });
      origCards.forEach(function (c) {
        track.insertBefore(c.cloneNode(true), track.firstChild);
      });

      var gap = parseFloat(getComputedStyle(track).gap) || 0;

      function cardW() {
        return track.children[0].offsetWidth + gap;
      }

      function jumpToMiddle(instant) {
        var w = cardW();
        if (instant) {
          scroller.style.scrollBehavior = 'auto';
          scroller.scrollLeft = w * n;
          scroller.style.scrollBehavior = '';
        }
      }

      requestAnimationFrame(function () { requestAnimationFrame(function () { jumpToMiddle(true); }); });

      var ticking = false;
      scroller.addEventListener('scroll', function () {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(function () {
          ticking = false;
          var w = cardW();
          var sl = scroller.scrollLeft;
          var total = w * n;
          if (sl < w * 0.5) {
            scroller.style.scrollBehavior = 'auto';
            scroller.scrollLeft = sl + total;
            scroller.style.scrollBehavior = '';
          } else if (sl >= w * (n * 2 - 0.5)) {
            scroller.style.scrollBehavior = 'auto';
            scroller.scrollLeft = sl - total;
            scroller.style.scrollBehavior = '';
          }
        });
      });

      /* ── Drag / swipe ── */
      var isDragging = false;
      var startX = 0;
      var scrollStart = 0;
      var velocity = 0;
      var lastX = 0;
      var lastTime = 0;

      function onPointerDown(e) {
        isDragging = true;
        startX = e.pageX || e.touches[0].pageX;
        scrollStart = scroller.scrollLeft;
        lastX = startX;
        lastTime = Date.now();
        velocity = 0;
        scroller.style.scrollSnapType = 'none';
        scroller.style.cursor = 'grabbing';
        scroller.classList.add('is-dragging');
      }

      function onPointerMove(e) {
        if (!isDragging) return;
        e.preventDefault();
        var x = e.pageX || e.touches[0].pageX;
        var now = Date.now();
        var dt = now - lastTime;
        if (dt > 0) velocity = (lastX - x) / dt;
        lastX = x;
        lastTime = now;
        scroller.scrollLeft = scrollStart - (x - startX);
      }

      function onPointerUp() {
        if (!isDragging) return;
        isDragging = false;
        scroller.style.cursor = '';
        scroller.classList.remove('is-dragging');
        var w = cardW();
        var momentum = velocity * 300;
        var target = Math.round((scroller.scrollLeft + momentum) / w) * w;
        scroller.style.scrollSnapType = '';
        scroller.scrollTo({ left: target, behavior: 'smooth' });
      }

      scroller.addEventListener('mousedown', onPointerDown);
      scroller.addEventListener('mousemove', onPointerMove);
      scroller.addEventListener('mouseup', onPointerUp);
      scroller.addEventListener('mouseleave', onPointerUp);
      scroller.addEventListener('touchstart', onPointerDown, { passive: true });
      scroller.addEventListener('touchmove', onPointerMove, { passive: false });
      scroller.addEventListener('touchend', onPointerUp);

      scroller.addEventListener('click', function (e) {
        if (Math.abs(lastX - startX) > 5) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);

      /* ── Next arrow ── */
      var nextBtn = carousel.querySelector('[data-portfolio-next]');
      if (nextBtn) {
        nextBtn.addEventListener('click', function () {
          stopAuto();
          scroller.scrollBy({ left: cardW(), behavior: 'smooth' });
          setTimeout(startAuto, 3000);
        });
      }

      /* ── Auto-play ── */
      var autoInterval = null;
      function startAuto() {
        stopAuto();
        autoInterval = setInterval(function () {
          scroller.scrollBy({ left: cardW(), behavior: 'smooth' });
        }, 6000);
      }
      function stopAuto() {
        if (autoInterval) { clearInterval(autoInterval); autoInterval = null; }
      }

      startAuto();
      carousel.addEventListener('mouseenter', stopAuto);
      carousel.addEventListener('mouseleave', startAuto);
      scroller.addEventListener('touchstart', stopAuto, { passive: true });
      scroller.addEventListener('touchend', function () { setTimeout(startAuto, 3000); });
    });
  })();
</script>

{% schema %}
{
  "name": "Portfolio Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Colore sfondo",
      "default": "#f5f3ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding superiore",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding inferiore",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine sfondo"
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stelle",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag (es. Cucine, Soggiorni)",
          "info": "Etichetta pill mostrata in alto."
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Testo recensione",
          "default": "Qualità eccezionale e un servizio clienti impeccabile. Non potremmo essere più soddisfatti!"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Foto autore"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Nome autore",
          "default": "Maria Rossi"
        },
        {
          "type": "text",
          "id": "author_role",
          "label": "Ruolo / Città",
          "default": "Milano"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Portfolio Carousel",
      "blocks": [
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" },
        { "type": "review_card" }
      ]
    }
  ]
}
{% endschema %}
