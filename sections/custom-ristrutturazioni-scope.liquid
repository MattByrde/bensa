{{ 'section-custom-ristrutturazioni-scope.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }
  #shopify-section-{{ section.id }} .rcm-scope {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round: 0 }}px;
  }
  #shopify-section-{{ section.id }} .rcm-scope__heading em,
  #shopify-section-{{ section.id }} .rcm-scope__item-icon {
    color: {{ section.settings.accent_color }};
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .rcm-scope {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="rcm-scope">
  <div class="rcm-scope__inner">
    <div class="rcm-scope__sticky">
      {%- if section.settings.eyebrow != blank -%}
        <p class="rcm-scope__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="rcm-scope__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="rcm-scope__desc">{{ section.settings.description }}</div>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="rcm-scope__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="rcm-scope__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <div class="rcm-scope__item" {{ block.shopify_attributes }}>
              {%- if block.settings.icon_svg != blank -%}
                <span class="rcm-scope__item-icon">{{ block.settings.icon_svg }}</span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h4>{{ block.settings.title }}</h4>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

