{{ 'section-custom-portfolio-works.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} {
    --text-color: {{ section.settings.text_color }};
  }
{%- endstyle -%}

<div class="portfolio-works" style="color: var(--text-color);">
  <div class="portfolio-works__header">
    <div class="portfolio-works__title">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="portfolio-works__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    <div class="portfolio-works__nav">
      <button class="portfolio-works__arrow portfolio-works__arrow--prev" data-pw-prev aria-label="Previous" disabled>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="portfolio-works__arrow portfolio-works__arrow--next" data-pw-next aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <div class="portfolio-works__carousel" data-portfolio-works-carousel>
    <div class="portfolio-works__track" data-portfolio-works-track>
      {%- for block in section.blocks -%}
        <div class="portfolio-works__slide" {{ block.shopify_attributes }}>
          
          <div class="portfolio-works__slide-left">
            <div class="portfolio-works__left-top">
              <div class="portfolio-works__titles">
                {%- if block.settings.title_word_1 != blank -%}
                  <span class="portfolio-works__title-box">{{ block.settings.title_word_1 }}</span>
                {%- endif -%}
                {%- if block.settings.title_word_2 != blank -%}
                  <span class="portfolio-works__title-box">{{ block.settings.title_word_2 }}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.subtitle != blank -%}
                <h3 class="portfolio-works__subtitle">{{ block.settings.subtitle }}</h3>
              {%- endif -%}
            </div>
            <div class="portfolio-works__left-bottom">
              {%- if block.settings.description != blank -%}
                <div class="portfolio-works__desc">{{ block.settings.description }}</div>
              {%- endif -%}
              {%- if block.settings.btn_label != blank -%}
                <div class="portfolio-works__btn-group">
                  <a href="{{ block.settings.btn_link | default: '#' }}" class="portfolio-works__btn">{{ block.settings.btn_label }}</a>
                  <a href="{{ block.settings.btn_link | default: '#' }}" class="portfolio-works__btn-circle" aria-label="{{ block.settings.btn_label }}" tabindex="-1">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </a>
                </div>
              {%- endif -%}
            </div>
          </div>

          <div class="portfolio-works__slide-right">
            <div class="portfolio-works__image">
              {%- if block.settings.video != blank -%}
                <video
                  class="portfolio-works__video"
                  src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
                  poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 800 }}{%- endif -%}"
                  loop muted playsinline preload="metadata"
                  data-pw-video
                ></video>
                <div class="portfolio-works__controls">
                  <button class="portfolio-works__control-btn" data-pw-play aria-label="Play / Pausa">
                    <svg class="portfolio-works__icon-pause" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="3" y="2" width="4" height="12" rx="1" fill="currentColor"/><rect x="9" y="2" width="4" height="12" rx="1" fill="currentColor"/></svg>
                    <svg class="portfolio-works__icon-play" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2.5L13 8L4 13.5V2.5Z" fill="currentColor"/></svg>
                  </button>
                  <button class="portfolio-works__control-btn" data-pw-mute aria-label="Muto / Riattiva audio">
                    <svg class="portfolio-works__icon-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><line x1="11" y1="5" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="15" y1="5" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    <svg class="portfolio-works__icon-unmuted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><path d="M11 5.5C11.8 6.3 12.25 7.4 12.25 8.5C12.25 9.6 11.8 10.7 11 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 3.5C14.3 4.8 15 6.6 15 8.5C15 10.4 14.3 12.2 13 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>
              {%- elsif block.settings.video_url != blank -%}
                <video
                  class="portfolio-works__video"
                  src="{{ block.settings.video_url }}"
                  poster="{%- if block.settings.image != blank -%}{{ block.settings.image | image_url: width: 800 }}{%- endif -%}"
                  loop muted playsinline preload="metadata"
                  data-pw-video
                ></video>
                <div class="portfolio-works__controls">
                  <button class="portfolio-works__control-btn" data-pw-play aria-label="Play / Pausa">
                    <svg class="portfolio-works__icon-pause" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="3" y="2" width="4" height="12" rx="1" fill="currentColor"/><rect x="9" y="2" width="4" height="12" rx="1" fill="currentColor"/></svg>
                    <svg class="portfolio-works__icon-play" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2.5L13 8L4 13.5V2.5Z" fill="currentColor"/></svg>
                  </button>
                  <button class="portfolio-works__control-btn" data-pw-mute aria-label="Muto / Riattiva audio">
                    <svg class="portfolio-works__icon-muted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><line x1="11" y1="5" x2="15" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="15" y1="5" x2="11" y2="11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    <svg class="portfolio-works__icon-unmuted" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2L4.5 5.5H2V10.5H4.5L8 14V2Z" fill="currentColor"/><path d="M11 5.5C11.8 6.3 12.25 7.4 12.25 8.5C12.25 9.6 11.8 10.7 11 11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M13 3.5C14.3 4.8 15 6.6 15 8.5C15 10.4 14.3 12.2 13 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  </button>
                </div>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>

        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;

    var carousel = section.querySelector('[data-portfolio-works-carousel]');
    var prevBtn = section.querySelector('[data-pw-prev]');
    var nextBtn = section.querySelector('[data-pw-next]');
    if (!carousel) return;

    var slides = carousel.querySelectorAll('.portfolio-works__slide');
    var currentIndex = 0;

    function getSlideStep() {
      if (!slides.length) return carousel.clientWidth;
      var slide = slides[0];
      var style = getComputedStyle(slide);
      return slide.offsetWidth + parseInt(style.marginRight, 10);
    }

    function goTo(index) {
      var maxIndex = slides.length - 1;
      currentIndex = Math.max(0, Math.min(index, maxIndex));
      carousel.scrollTo({ left: currentIndex * getSlideStep(), behavior: 'smooth' });
    }

    function updateArrows() {
      var step = getSlideStep();
      currentIndex = Math.round(carousel.scrollLeft / step);
      if (prevBtn) prevBtn.disabled = currentIndex <= 0;
      if (nextBtn) nextBtn.disabled = currentIndex >= slides.length - 1;
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(currentIndex - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(currentIndex + 1); });

    /* Reset to first slide on load */
    carousel.scrollLeft = 0;

    carousel.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();

    /* Drag to scroll */
    var isDragging = false;
    var startX = 0;
    var scrollStart = 0;

    carousel.addEventListener('mousedown', function (e) {
      isDragging = true;
      startX = e.pageX;
      scrollStart = carousel.scrollLeft;
      carousel.style.cursor = 'grabbing';
      carousel.style.scrollSnapType = 'none';
      e.preventDefault();
    });

    window.addEventListener('mousemove', function (e) {
      if (!isDragging) return;
      carousel.scrollLeft = scrollStart - (e.pageX - startX);
    });

    window.addEventListener('mouseup', function () {
      if (!isDragging) return;
      isDragging = false;
      carousel.style.cursor = '';
      carousel.style.scrollSnapType = 'x mandatory';
    });

    /* Video controls */
    section.querySelectorAll('.portfolio-works__image').forEach(function (wrap) {
      var video = wrap.querySelector('[data-pw-video]');
      if (!video) return;

      if (window.IntersectionObserver) {
        new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              video.play().catch(function () {});
              wrap.classList.add('is-playing');
            } else {
              video.pause();
              wrap.classList.remove('is-playing');
            }
          });
        }, { threshold: 0.4 }).observe(wrap);
      }

      var playBtn = wrap.querySelector('[data-pw-play]');
      var muteBtn = wrap.querySelector('[data-pw-mute]');

      if (playBtn) {
        playBtn.addEventListener('click', function () {
          if (video.paused) {
            video.play().catch(function () {});
            wrap.classList.add('is-playing');
          } else {
            video.pause();
            wrap.classList.remove('is-playing');
          }
        });
      }

      if (muteBtn) {
        muteBtn.addEventListener('click', function () {
          video.muted = !video.muted;
          wrap.classList.toggle('is-unmuted', !video.muted);
        });
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Portfolio Works Carousel",
  "tag": "section",
  "class": "section-portfolio-works",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Pre-titolo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Le Nostre Realizzazioni"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "portfolio_item",
      "name": "Portfolio Item",
      "settings": [
        {
          "type": "text",
          "id": "title_word_1",
          "label": "Title Box 1",
          "default": "Liminal"
        },
        {
          "type": "text",
          "id": "title_word_2",
          "label": "Title Box 2",
          "default": "Dreaming"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "The Drake Hotel, Modern Wing Lobby"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "EXPLORE"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (Shopify)",
          "info": "Ha priorità sull'immagine."
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "URL video esterno (.mp4)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Immagine / Poster video"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "ART, DESIGN, AND NATURE COME TOGETHER IN ONE TOUR DE FORCE."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Portfolio Works Carousel",
      "blocks": [
        { "type": "portfolio_item" },
        { "type": "portfolio_item" }
      ]
    }
  ]
}
{% endschema %}
