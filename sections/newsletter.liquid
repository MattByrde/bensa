{%- comment -%} Newsletter Section — Full-width hero style {%- endcomment -%}

<section class="newsletter" data-section-id="{{ section.id }}" style="min-height: {{ section.settings.height }}vh;">

  {%- comment -%} Background image {%- endcomment -%}
  <div class="newsletter__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1920 | image_tag:
        class: 'newsletter__bg-img',
        loading: 'lazy',
        sizes: '100vw',
        widths: '750, 1100, 1500, 1920'
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'newsletter__bg-img placeholder-svg' }}
    {%- endif -%}
  </div>

  <div class="newsletter__overlay"></div>

  <div class="newsletter__inner">
    <div class="newsletter__content">
      {%- if section.settings.subtitle != blank -%}
        <span class="newsletter__subtitle">{{ section.settings.subtitle }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter__heading typo-h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="newsletter__text typo-body">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__form-row">
          <input
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="{{ 'newsletter.email_placeholder' | t }}"
            required
            autocomplete="email"
            aria-label="{{ 'newsletter.email_placeholder' | t }}"
          >
          <button type="submit" class="newsletter__btn typo-btn">
            {{ 'newsletter.submit' | t }}
          </button>
        </div>
      {%- endform -%}

      {%- if section.settings.privacy_text != blank -%}
        <label class="newsletter__privacy newsletter__privacy--checkbox typo-caption">
          <input type="checkbox" name="contact[privacy]" required class="newsletter__checkbox">
          <span>{{ section.settings.privacy_text }}</span>
        </label>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine di sfondo"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Altezza sezione",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 60
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sottotitolo",
      "default": "Resta Aggiornato"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Iscriviti alla Newsletter"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Ricevi in anteprima le ultime novità, consigli di design e offerte esclusive riservate ai nostri iscritti."
    },
    {
      "type": "richtext",
      "id": "privacy_text",
      "label": "Privacy Policy Text",
      "default": "<p>Iscrivendoti, accetti la nostra <a href=\"/policies/privacy-policy\">Privacy Policy</a> e acconsenti a ricevere comunicazioni commerciali.</p>"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
