{%- comment -%} Newsletter Section {%- endcomment -%}

<section class="newsletter" data-section-id="{{ section.id }}">
  <div class="newsletter__layout">
    <div class="newsletter__image">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 800 | image_tag: class: 'newsletter__img', loading: 'lazy' }}
      {%- else -%}
        <div class="newsletter__img-placeholder">
          <svg class="newsletter__img-placeholder-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
      {%- endif -%}
    </div>

    <div class="newsletter__body">
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter__heading typo-h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="newsletter__text typo-body">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter__form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter__form-row">
          <input
            type="email"
            name="contact[email]"
            class="newsletter__input"
            placeholder="{{ 'newsletter.email_placeholder' | t }}"
            required
            autocomplete="email"
            aria-label="{{ 'newsletter.email_placeholder' | t }}"
          >
          <button type="submit" class="newsletter__btn typo-btn">
            {{ 'newsletter.submit' | t }}
          </button>
        </div>
      {%- endform -%}

      {%- if section.settings.privacy_text != blank -%}
        <label class="newsletter__privacy newsletter__privacy--checkbox typo-caption">
          <input type="checkbox" name="contact[privacy]" required class="newsletter__checkbox">
          <span>{{ section.settings.privacy_text }}</span>
        </label>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay in touch"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Sign up for updates on new collections, design tips, and exclusive offers."
    },
    {
      "type": "richtext",
      "id": "privacy_text",
      "label": "Privacy Policy Text",
      "default": "<p>By signing up, you agree to our <a href=\"/policies/privacy-policy\">Privacy Policy</a> and consent to receive marketing communications.</p>"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
