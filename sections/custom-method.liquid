{{ 'section-custom-method.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<div class="method" data-method-section>
  <div class="method__layout">

    {%- comment -%} Scattered images — spread across the full section, behind text {%- endcomment -%}
    <div class="method__images-col">
      {%- assign media_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'media' -%}
          {%- assign media_index = media_index | plus: 1 -%}
          <div
            class="method__img-wrap method__img-wrap--{{ media_index }} method__img-wrap--{{ block.settings.size }}"
            data-method-media
            data-parallax-speed="{{ block.settings.parallax_speed }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.video != blank -%}
              <video class="method__media-asset" autoplay muted loop playsinline>
                {%- for source in block.settings.video.sources -%}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {%- endfor -%}
              </video>
            {%- elsif block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: class: 'method__media-asset', loading: 'lazy' }}
            {%- else -%}
              <div class="method__media-placeholder"></div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} Text column — centered sticky panels {%- endcomment -%}
    <div class="method__text-col">
      <div class="method__text-sticky">
        {%- assign panel_index = 0 -%}
        {%- assign step_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'intro' -%}
            <div
              class="method__panel-wrap method__panel-wrap--intro{% if panel_index == 0 %} method__panel-wrap--active{% endif %}"
              data-method-panel="{{ panel_index }}"
              data-bg-color="{{ block.settings.background_color | default: section.settings.background_color }}"
            >
              <div class="method__panel" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="method__heading">{{ block.settings.heading }}</h2>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="method__description">{{ block.settings.text }}</p>
                {%- endif -%}
                {%- if block.settings.link_label != blank -%}
                  <a href="{{ block.settings.link | default: '#' }}" class="method__link">
                    {{ block.settings.link_label }}
                  </a>
                {%- endif -%}
              </div>
            </div>
            {%- assign panel_index = panel_index | plus: 1 -%}

          {%- elsif block.type == 'step' -%}
            {%- assign step_count = step_count | plus: 1 -%}
            <div
              class="method__panel-wrap{% if panel_index == 0 %} method__panel-wrap--active{% endif %}"
              data-method-panel="{{ panel_index }}"
              data-bg-color="{{ block.settings.background_color | default: section.settings.background_color }}"
            >
              <div class="method__panel" {{ block.shopify_attributes }}>
                <span class="method__step-number">{{ step_count }}</span>
                {%- if block.settings.title != blank -%}
                  <h3 class="method__step-heading">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="method__step-text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>
            {%- assign panel_index = panel_index | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.querySelector('[data-method-section]');
    if (!section) return;

    var panels = Array.from(section.querySelectorAll('[data-method-panel]'));
    var mediaItems = Array.from(section.querySelectorAll('[data-method-media]'));
    var ticking = false;
    var currentPanel = 0;
    var currentColor = '';

    if (panels.length === 0) return;

    var metrics = {
      sectionTop: 0,
      sectionHeight: 0,
      viewportH: 0,
      step: 1,
      mediaStarts: []
    };

    function recomputeMetrics() {
      var sectionRect = section.getBoundingClientRect();
      metrics.sectionTop = window.pageYOffset + sectionRect.top;
      metrics.sectionHeight = sectionRect.height;
      metrics.viewportH = window.innerHeight;
      var scrollRange = metrics.sectionHeight - metrics.viewportH;
      if (scrollRange <= 0) scrollRange = 1;
      metrics.step = scrollRange / panels.length;
      metrics.mediaStarts = mediaItems.map(function (item) {
        var r = item.getBoundingClientRect();
        return {
          top: window.pageYOffset + r.top,
          height: r.height,
          speed: (parseFloat(item.getAttribute('data-parallax-speed')) || 5) / 10
        };
      });
    }

    function update() {
      ticking = false;
      var scrolled = window.pageYOffset;
      var viewportH = metrics.viewportH;

      // Skip work when the section is fully offscreen
      var sectionBottom = metrics.sectionTop + metrics.sectionHeight;
      if (scrolled + viewportH < metrics.sectionTop || scrolled > sectionBottom) return;

      var progress = scrolled - metrics.sectionTop;
      var activeIndex = Math.floor(progress / metrics.step);
      if (activeIndex < 0) activeIndex = 0;
      else if (activeIndex > panels.length - 1) activeIndex = panels.length - 1;

      if (activeIndex !== currentPanel) {
        panels[currentPanel].classList.remove('method__panel-wrap--active');
        panels[activeIndex].classList.add('method__panel-wrap--active');
        currentPanel = activeIndex;
      }

      var activeColor = panels[currentPanel].getAttribute('data-bg-color') || '';
      if (activeColor !== currentColor) {
        section.style.backgroundColor = activeColor;
        currentColor = activeColor;
      }

      for (var i = 0; i < mediaItems.length; i++) {
        var item = mediaItems[i];
        var m = metrics.mediaStarts[i];
        if (!m) continue;
        var itemCenterDoc = m.top + m.height / 2;
        var itemCenterViewport = itemCenterDoc - scrolled;
        var reveal = (viewportH - itemCenterViewport) / (viewportH * 0.35);
        if (reveal < 0) reveal = 0;
        else if (reveal > 1) reveal = 1;
        var eased = 1 - Math.pow(1 - reveal, 3);
        var y = scrolled * m.speed * 0.1;
        item.style.opacity = eased;
        item.style.transform = 'translateY(' + (-(y) + 40 * (1 - eased)) + 'px) scale(' + (0.9 + 0.1 * eased) + ')';
      }
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    }

    if (window.ResizeObserver) {
      var ro = new ResizeObserver(recomputeMetrics);
      ro.observe(section);
    }
    window.addEventListener('resize', recomputeMetrics, { passive: true });
    window.addEventListener('load', recomputeMetrics);

    recomputeMetrics();
    window.addEventListener('scroll', onScroll, { passive: true });
    requestAnimationFrame(update);
  });
</script>

{% schema %}
{
  "name": "The Method",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    }
  ],
  "blocks": [
    {
      "type": "intro",
      "name": "Intro Text",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Il Metodo Bensa"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Non vintage, non moderno. Il nostro metodo di design prende un approccio raccolto e autentico, utilizzando pezzi ben costruiti con carattere senza tempo, a prescindere dalla loro età. Da Bensa, crediamo che il carattere sia la pietra angolare degli interni senza tempo. Creiamo pezzi fatti per invecchiare e vivere attraverso le generazioni."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "SCOPRI DI PIÙ"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background Color",
          "default": "#f5f3ec"
        }
      ]
    },
    {
      "type": "media",
      "name": "Image / Video",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (overrides image)"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "xs", "label": "Small square" },
            { "value": "sm", "label": "Medium square" },
            { "value": "lg", "label": "Large square" },
            { "value": "vt", "label": "Vertical" },
            { "value": "hz", "label": "Horizontal" }
          ],
          "default": "sm"
        },
        {
          "type": "range",
          "id": "parallax_speed",
          "label": "Parallax Speed",
          "min": 1,
          "max": 10,
          "step": 1,
          "default": 5,
          "info": "1 = slow drift, 10 = fast"
        }
      ]
    },
    {
      "type": "step",
      "name": "Method Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "IL DESIGNER"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Il nostro processo inizia nelle mani del designer, dove generazioni di esperienza vengono sviluppate a partire da uno schizzo."
        },
        {
          "type": "color",
          "id": "background_color",
          "label": "Background Color",
          "default": "#f5f3ec"
        }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "The Method",
      "blocks": [
        { "type": "intro", "settings": { "heading": "Il Metodo Bensa", "text": "Non vintage, non moderno. Il nostro metodo di design prende un approccio raccolto e autentico, utilizzando pezzi ben costruiti con carattere senza tempo, a prescindere dalla loro età. Da Bensa, crediamo che il carattere sia la pietra angolare degli interni senza tempo. Creiamo pezzi fatti per invecchiare e vivere attraverso le generazioni.", "link_label": "SCOPRI DI PIÙ" } },
        { "type": "media", "settings": { "size": "lg", "parallax_speed": 2 } },
        { "type": "media", "settings": { "size": "vt", "parallax_speed": 5 } },
        { "type": "media", "settings": { "size": "xs", "parallax_speed": 8 } },
        { "type": "media", "settings": { "size": "lg", "parallax_speed": 3 } },
        { "type": "media", "settings": { "size": "lg", "parallax_speed": 4 } },
        { "type": "media", "settings": { "size": "lg", "parallax_speed": 2 } },
        { "type": "media", "settings": { "size": "xs", "parallax_speed": 9 } },
        { "type": "media", "settings": { "size": "xs", "parallax_speed": 7 } },
        { "type": "media", "settings": { "size": "hz", "parallax_speed": 5 } },
        { "type": "media", "settings": { "size": "xs", "parallax_speed": 6 } },
        { "type": "media", "settings": { "size": "lg", "parallax_speed": 3 } },
        { "type": "step", "settings": { "title": "IL DESIGNER", "text": "Il nostro processo inizia nelle mani del designer, dove generazioni di esperienza vengono sviluppate a partire da uno schizzo fatto a mano e trasformate dal nostro team di ingegneri. Le finiture sono determinate con la massima qualità degli interni in mente, per garantire la longevità di ogni pezzo." } },
        { "type": "step", "settings": { "title": "L'ARTIGIANO", "text": "Il progetto viene poi affidato all'artigiano per dare vita alla forma e alla struttura. Ore dedicate alla sagomatura, levigatura, assemblaggio e cucitura con il tocco della mano umana, poi meticolosamente ispezionato per il controllo qualità su ogni pezzo." } },
        { "type": "step", "settings": { "title": "IL REALIZZATORE", "text": "Un prototipo finale viene poi passato ai laboratori dei realizzatori per essere prodotto, curando ogni minimo dettaglio: tessuti, cuciture, stampe e timbri applicati, e firmato ad ogni passaggio." } }
      ]
    }
  ]
}
{% endschema %}
