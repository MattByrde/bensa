{{ 'section-custom-team.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="team">
  <div class="team__layout">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="team__intro">
        {%- if section.settings.heading != blank -%}
          <h2 class="typo-section-heading team__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="team__description">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.intro_button_label != blank or section.settings.intro_button_2_label != blank -%}
          <div class="team__intro-buttons">
            {%- if section.settings.intro_button_label != blank -%}
              <a href="{{ section.settings.intro_button_link | default: '#' }}" class="team__btn team__btn--primary">
                {{ section.settings.intro_button_label }}
              </a>
            {%- endif -%}
            {%- if section.settings.intro_button_2_label != blank -%}
              <a href="{{ section.settings.intro_button_2_link | default: '#' }}" class="team__btn team__btn--outline">
                {{ section.settings.intro_button_2_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="team__body">
    {%- if section.blocks.size > 0 -%}
    {%- liquid
      assign has_sub_label = false
      for block in section.blocks
        if block.type == 'sub_label'
          assign has_sub_label = true
          break
        endif
      endfor
    -%}

    {%- if has_sub_label -%}
      {%- assign open_grid = false -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'sub_label' -%}
          {%- if open_grid -%}
            </div>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="team__sub-label" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- endif -%}
          <div class="team__grid">
          {%- assign open_grid = true -%}
        {%- elsif block.type == 'person' -%}
          {%- unless open_grid -%}
            <div class="team__grid">
            {%- assign open_grid = true -%}
          {%- endunless -%}
          <div class="team-card" {{ block.shopify_attributes }}>
            <div class="team-card__photo" style="background-color: {{ block.settings.fallback_color }};">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.name }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            {%- if block.settings.role != blank -%}
              <div class="team-card__role">{{ block.settings.role }}</div>
            {%- endif -%}
            {%- if block.settings.name != blank -%}
              <div class="team-card__name">{{ block.settings.name }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
      {%- if open_grid -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="team__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'person' -%}
            <div class="team-card" {{ block.shopify_attributes }}>
              <div class="team-card__photo" style="background-color: {{ block.settings.fallback_color }};">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.name }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              {%- if block.settings.role != blank -%}
                <div class="team-card__role">{{ block.settings.role }}</div>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <div class="team-card__name">{{ block.settings.name }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    {%- endif -%}
    </div>
  </div>


</div>

{% schema %}
{
  "name": "Team Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Use italic for emphasised words",
      "default": "<p>Built By World-Class <em>Business</em> Experts</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our team combines strategic insight with hands-on execution capabilities, supporting clients through every phase of complex financial decisions — from early structuring to delivery and long-term asset management."
    },
    {
      "type": "text",
      "id": "intro_button_label",
      "label": "Intro button label"
    },
    {
      "type": "url",
      "id": "intro_button_link",
      "label": "Intro button link"
    },
    {
      "type": "header",
      "content": "Section"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "sub_label",
      "name": "Sub label (divider)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Label text",
          "info": "Divides the grid by role (e.g. 'Founders', 'Designers')",
          "default": "Our Experts"
        }
      ]
    },
    {
      "type": "person",
      "name": "Person",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "color",
          "id": "fallback_color",
          "label": "Fallback color",
          "default": "#e8e2d9"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role",
          "info": "Shown above the name (bold italic)",
          "default": "Employee"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Anna Smith"
        }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Team Grid",
      "blocks": [
        { "type": "sub_label", "settings": { "text": "Founders" } },
        { "type": "person", "settings": { "role": "CEO", "name": "Anna Smith" } },
        { "type": "person", "settings": { "role": "CTO", "name": "Giovanni Ser." } },
        { "type": "person", "settings": { "role": "CFO", "name": "Marco Tel." } },
        { "type": "sub_label", "settings": { "text": "Team" } },
        { "type": "person", "settings": { "role": "Employee", "name": "Marta Bass." } },
        { "type": "person", "settings": { "role": "Employee", "name": "Anna Smith" } },
        { "type": "person", "settings": { "role": "Employee", "name": "Anna Smith" } },
        { "type": "person", "settings": { "role": "Employee", "name": "Anna Smith" } },
        { "type": "person", "settings": { "role": "CTO 1", "name": "Anna Smith" } },
        { "type": "person", "settings": { "role": "Employee", "name": "Anna Smith" } },
        { "type": "person", "settings": { "role": "Employee", "name": "Anna Smith" } }
      ]
    }
  ]
}
{% endschema %}
