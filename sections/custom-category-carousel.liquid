<link rel="stylesheet" href="{{ 'section-custom-category-carousel.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-category-carousel.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="custom-category-carousel">
  <!-- Carousel Track -->
  <div class="ccc-cards-wrapper">
    <div class="ccc-cards-track">
      {%- for block in section.blocks -%}
        {%- if block.type == 'carousel_card' -%}
          <div class="ccc-card" {{ block.shopify_attributes }}>
            
            {%- comment -%} Background Media {%- endcomment -%}
            <div class="ccc-card-media">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'ccc-media' }}
              {%- elsif block.settings.video_url != blank -%}
                <video class="ccc-media" autoplay loop muted playsinline>
                  <source src="{{ block.settings.video_url }}" type="video/mp4">
                </video>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 800 | image_tag: class: 'ccc-media', loading: 'lazy' }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'ccc-media placeholder-svg' }}
              {%- endif -%}
            </div>

            {%- comment -%} Gradient Overlay {%- endcomment -%}
            <div class="ccc-card-overlay"></div>



            {%- comment -%} Bottom Content {%- endcomment -%}
            <div class="ccc-card-content">
              {%- if block.settings.use_interactive_buttons -%}
                <div class="ccc-interactive-wrapper">
                  {%- if block.settings.show_play_icon -%}
                    <div class="ccc-play-icon-center">
                      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="32" cy="32" r="32" fill="white" fill-opacity="0.9"/>
                        <path d="M42 32L27 41V23L42 32Z" fill="black"/>
                      </svg>
                    </div>
                  {%- endif -%}
                  <div class="ccc-interactive-bottom">
                    <div class="ccc-interactive-buttons">
                      {%- if block.settings.btn1_label != blank -%}
                        <a href="{{ block.settings.btn1_link | default: '#' }}" class="ccc-btn-interactive typo-small">
                          <span class="ccc-btn-badge ccc-badge-a">A</span>
                          <span class="ccc-btn-label">{{ block.settings.btn1_label }}</span>
                        </a>
                      {%- endif -%}
                      {%- if block.settings.btn2_label != blank -%}
                        <a href="{{ block.settings.btn2_link | default: '#' }}" class="ccc-btn-interactive typo-small">
                          <span class="ccc-btn-badge ccc-badge-b">B</span>
                          <span class="ccc-btn-label">{{ block.settings.btn2_label }}</span>
                        </a>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              {%- else -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="ccc-card-title typo-h3">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.subtitle != blank -%}
                  <p class="ccc-card-subtitle typo-overline">{{ block.settings.subtitle }}</p>
                {%- endif -%}
                {%- if block.settings.button_label != blank -%}
                  {%- assign btn_class = 'ccc-card-btn' -%}
                  {%- if block.settings.button_style == 'blue' -%}
                    {%- assign btn_class = 'ccc-card-btn ccc-btn-blue' -%}
                  {%- endif -%}
                  <a href="{{ block.settings.button_link | default: '#' }}" class="{{ btn_class }} typo-btn">{{ block.settings.button_label }}</a>
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Categories Track -->
  <div class="ccc-categories-wrapper">
    <div class="ccc-categories-track">
      {%- for block in section.blocks -%}
        {%- if block.type == 'category_pill' -%}
          <a href="{{ block.settings.link | default: '#' }}" class="ccc-category-pill" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 40 | image_tag: class: 'ccc-cat-icon', loading: 'lazy' }}
            {%- else -%}
              <svg class="ccc-cat-icon default-icon" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9"/>
              </svg>
            {%- endif -%}
            <span class="ccc-cat-label typo-overline">{{ block.settings.label }}</span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Category Carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "carousel_card",
      "name": "Carousel Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Background Video (Shopify)"
        },
        {
          "type": "text",
          "id": "video_url",
          "label": "Video URL (MP4 fallback, external)",
          "info": "Use if you host the video externally."
        },
        {
          "type": "header",
          "content": "Center Play Icon"
        },
        {
          "type": "checkbox",
          "id": "show_play_icon",
          "label": "Show center play icon",
          "default": false
        },
        {
          "type": "text",
          "id": "play_icon_text",
          "label": "Text under play icon (optional)",
          "default": "dalla tua casa"
        },
        {
          "type": "header",
          "content": "Card Content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "DIVANO MAX"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subheading",
          "default": "LOREM IPSUM DOLOR SIT AMET, CONSECTETUR ADIPISCING ELIT. SUSPENDISSE VARIUS ENIM."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SCOPRI LA COLLEZIONE"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "white", "label": "White (Rounded)" },
            { "value": "blue", "label": "Blue (Full Width)" }
          ],
          "default": "white"
        },
        {
          "type": "header",
          "content": "Interactive Features"
        },
        {
          "type": "checkbox",
          "id": "use_interactive_buttons",
          "label": "Use Interactive Buttons Overlay",
          "info": "Replaces the heading/button with two contextual buttons.",
          "default": false
        },
        {
          "type": "text",
          "id": "btn1_label",
          "label": "Button A Label",
          "default": "Scopri l'interno"
        },
        {
          "type": "url",
          "id": "btn1_link",
          "label": "Button A Link"
        },
        {
          "type": "text",
          "id": "btn2_label",
          "label": "Button B Label",
          "default": "Voglio acquisrarlo"
        },
        {
          "type": "url",
          "id": "btn2_link",
          "label": "Button B Link"
        }
      ]
    },
    {
      "type": "category_pill",
      "name": "Category Pill",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Outline SVG or PNG"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "SEDIE"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Carousel",
      "blocks": [
        { "type": "carousel_card" },
        { "type": "carousel_card" },
        { "type": "carousel_card" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" }
      ]
    }
  ]
}
{% endschema %}
