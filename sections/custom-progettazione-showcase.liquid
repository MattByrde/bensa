{{ 'section-custom-progettazione-showcase.css' | asset_url | stylesheet_tag: preload: true }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #shopify-section-{{ section.id }} .prog-showcase {
    background-color: {{ section.settings.bg_color }};
  }
{%- endstyle -%}

<div class="prog-showcase">
  <div class="prog-showcase__inner">

    {%- comment -%} Left: sticky heading only {%- endcomment -%}
    <div class="prog-showcase__text">
      {%- if section.settings.heading != blank -%}
        <h2 class="prog-showcase__heading typo-h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="prog-showcase__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Right: rows of 3 images + row text on the right {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="prog-showcase__grid" data-showcase-grid>
        {%- for block in section.blocks -%}
          <div class="prog-showcase__row{% if forloop.first %} is-active{% endif %}" data-showcase-row {{ block.shopify_attributes }}>

            {%- for i in (1..3) -%}
              {%- assign img_key = 'image_' | append: i -%}
              <div class="prog-showcase__item">
                {%- if block.settings[img_key] != blank -%}
                  {{ block.settings[img_key] | image_url: width: 600 | image_tag: loading: 'lazy', class: 'prog-showcase__img' }}
                {%- else -%}
                  <div class="prog-showcase__placeholder">
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}

            <div class="prog-showcase__row-text">
              {%- if block.settings.title != blank -%}
                <p class="prog-showcase__row-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="prog-showcase__row-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<script>
  (function () {
    var rows = document.querySelectorAll('[data-showcase-row]');
    if (!rows.length) return;

    var navbar = document.querySelector('.site-header');
    function getNavbarHeight() {
      return navbar ? navbar.offsetHeight : 80;
    }

    var scrollActive = rows[0];

    function setActive(row) {
      rows.forEach(function (r) { r.classList.remove('is-active'); });
      if (row) row.classList.add('is-active');
    }

    function check() {
      var trigger = getNavbarHeight();
      var current = null;
      rows.forEach(function (row) {
        if (row.getBoundingClientRect().top <= trigger) {
          current = row;
        }
      });
      if (current !== scrollActive) {
        scrollActive = current;
        setActive(scrollActive);
      }
    }

    rows.forEach(function (row) {
      row.addEventListener('mouseenter', function () {
        setActive(row);
      });
      row.addEventListener('mouseleave', function () {
        setActive(scrollActive);
      });
    });

    window.addEventListener('scroll', check, { passive: true });
    check();
  })();
</script>

{% schema %}
{
  "name": "Progettazione Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore sfondo",
      "default": "#202020"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titolo",
      "default": "Collezioni esclusive con designer e artigiani che condividono la nostra visione"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sottotesto"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Testo bottone"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link bottone"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Riga",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Immagine 1"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Immagine 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Immagine 3"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titolo riga"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descrizione riga"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Progettazione Showcase",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "title": "In armonia",
            "description": "Lavoriamo fianco a fianco e impariamo dai designer che condividono la nostra visione. Perché quando è collettivo, la nostra prospettiva va più lontano."
          }
        },
        {
          "type": "row",
          "settings": {
            "title": "Artigianalità europea",
            "description": "Produciamo in modo equo e trasparente, in collaborazione con artigiani europei. Manteniamo la produzione locale, garantendo qualità e responsabilità in ogni fase."
          }
        },
        {
          "type": "row",
          "settings": {
            "title": "Il design al centro",
            "description": "Ogni progetto nasce dall'ascolto e prende forma attraverso la creatività condivisa tra designer, artigiani e clienti."
          }
        }
      ]
    }
  ]
}
{% endschema %}
