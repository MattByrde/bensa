<link rel="stylesheet" href="{{ 'section-custom-progettazione-bar.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-progettazione-bar.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} .prog-bar {
    background-color: {{ section.settings.bg_color }};
  }
{%- endstyle -%}

<div class="prog-bar">
  <div class="prog-bar__inner">

    {%- for block in section.blocks -%}
      <div class="prog-bar__item" {{ block.shopify_attributes }}>
        <div class="prog-bar__icon">
          {%- case block.settings.icon -%}
            {%- when 'ruler' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h18M3 7l2-2M3 7l2 2M21 7l-2-2M21 7l-2 2M3 17h18M3 17l2-2M3 17l2 2M21 17l-2-2M21 17l-2 2"/><rect x="3" y="7" width="18" height="10" rx="1"/></svg>
            {%- when 'cube' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3L2 8l10 5 10-5-10-5z"/><path d="M2 16l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            {%- when 'pencil' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.232 5.232l3.536 3.536M9 13l-4 1 1-4L17.5 3.5a2.121 2.121 0 013 3L9 13z"/></svg>
            {%- when 'home' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 01-1 1H4a1 1 0 01-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg>
            {%- when 'star' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- when 'tools' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.77 3.77z"/></svg>
            {%- when 'chat' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            {%- when 'check' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          {%- endcase -%}
        </div>
        <div class="prog-bar__text">
          <span class="prog-bar__label">{{ block.settings.label }}</span>
          {%- if block.settings.description != blank -%}
            <span class="prog-bar__desc">{{ block.settings.description }}</span>
          {%- endif -%}
        </div>
      </div>

    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Progettazione Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore sfondo",
      "default": "#beb9b3"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Caratteristica",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icona",
          "options": [
            { "value": "pencil",  "label": "Matita (Progettazione)" },
            { "value": "ruler",   "label": "Righello (Rilievo)" },
            { "value": "cube",    "label": "Cubo 3D (Rendering)" },
            { "value": "tools",   "label": "Attrezzi (Installazione)" },
            { "value": "home",    "label": "Casa" },
            { "value": "chat",    "label": "Consulenza" },
            { "value": "star",    "label": "Qualità" },
            { "value": "check",   "label": "Garanzia" }
          ],
          "default": "pencil"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etichetta",
          "default": "Progettazione 3D"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Descrizione breve",
          "default": "Rendering realistici prima dell'installazione"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Progettazione Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "chat",
            "label": "Consulenza gratuita",
            "description": "Ascoltiamo ogni tua esigenza in showroom"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "pencil",
            "label": "Progettazione 3D",
            "description": "Rendering realistici prima dell'installazione"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "ruler",
            "label": "Rilievo preciso",
            "description": "Misurazioni laser per la massima precisione"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "tools",
            "label": "Installazione chiavi in mano",
            "description": "Tecnici specializzati, cura nei dettagli"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "check",
            "label": "Assistenza post-vendita",
            "description": "Supporto continuo anche dopo la consegna"
          }
        }
      ]
    }
  ]
}
{% endschema %}
