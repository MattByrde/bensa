{{ 'section-custom-values-grid.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }
</style>

<div class="values-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.heading != blank -%}
    <h3 class="typo-section-heading values-section__heading">{{ section.settings.heading | remove: '<p>' | remove: '</p>' }}</h3>
  {%- endif -%}

  <div class="values-grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'text_card' -%}
          <div class="values-card values-card--text" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h4 class="typo-card-title values-card__title">{{ block.settings.title }}</h4>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="values-card__description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>

        {%- when 'image_card' -%}
          <div class="values-card values-card--image" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'values-card__img' }}
            {%- else -%}
              <div class="values-card__placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Values Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>I <em>valori</em> che ci guidano</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "text_card",
      "name": "Text Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Viaggio appassionato"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "image_card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Values Grid",
      "blocks": [
        { "type": "text_card", "settings": { "title": "Viaggio appassionato", "description": "Il nostro viaggio è una storia di vero amore per il design, che ha dato vita a un marchio elegante e diversificato." } },
        { "type": "text_card", "settings": { "title": "Squadra unita", "description": "La nostra forza risiede nello spirito collaborativo e in una curiosità insaziabile." } },
        { "type": "image_card" },
        { "type": "text_card", "settings": { "title": "Ispirazioni globali", "description": "Le nostre esperienze, ricche e internazionali, attingono dalla varietà delle culture mondiali." } },
        { "type": "image_card" },
        { "type": "text_card", "settings": { "title": "Sviluppo sostenibile", "description": "Diamo priorità alla sostenibilità, abbracciando pratiche ecologiche insieme alla migliore maestria artigianale." } },
        { "type": "image_card" },
        { "type": "text_card", "settings": { "title": "Invito alla creatività", "description": "Le nostre collezioni invitano alla creazione di interni armoniosi e confortevoli." } }
      ]
    }
  ]
}
{% endschema %}
