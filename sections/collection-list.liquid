{%- comment -%} Collection List Section {%- endcomment -%}

<section class="section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="featured-collection__header">
        {%- if section.settings.subtitle != blank -%}
          <p class="featured-collection__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        <h2 class="featured-collection__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="grid grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.collection.url | default: '#' }}" class="collection-list__item" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img
              class="collection-list__image"
              src="{{ block.settings.image | image_url: width: 800 }}"
              srcset="
                {{ block.settings.image | image_url: width: 400 }} 400w,
                {{ block.settings.image | image_url: width: 600 }} 600w,
                {{ block.settings.image | image_url: width: 800 }} 800w
              "
              sizes="(max-width: 749px) 100vw, (max-width: 989px) 50vw, 25vw"
              alt="{{ block.settings.collection.title | default: block.settings.title | escape }}"
              loading="lazy"
            >
          {%- elsif block.settings.collection.image -%}
            <img
              class="collection-list__image"
              src="{{ block.settings.collection.image | image_url: width: 800 }}"
              alt="{{ block.settings.collection.title | escape }}"
              loading="lazy"
            >
          {%- else -%}
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-list__image' }}
          {%- endif -%}
          <div class="collection-list__overlay">
            <h3 class="collection-list__name">
              {{ block.settings.title | default: block.settings.collection.title | default: 'Collection' }}
            </h3>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "class": "section-collection-list",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Browse by room"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection", "settings": { "title": "Living Room" } },
        { "type": "collection", "settings": { "title": "Bedroom" } },
        { "type": "collection", "settings": { "title": "Dining" } },
        { "type": "collection", "settings": { "title": "Office" } }
      ]
    }
  ]
}
{% endschema %}
