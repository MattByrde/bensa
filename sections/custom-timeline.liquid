{{ 'section-custom-timeline.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="timeline">
  <div class="timeline__inner">

    {%- comment -%} Section header — matches about-showcase / values-grid pattern {%- endcomment -%}
    {%- if section.settings.kicker != blank or section.settings.heading != blank or section.settings.description != blank -%}
      <div class="timeline__header">
        {%- if section.settings.kicker != blank -%}
          <span class="timeline__kicker">{{ section.settings.kicker }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="typo-section-heading timeline__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="timeline__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ol class="timeline__list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'milestone' -%}
          <li class="timeline__item timeline__reveal" {{ block.shopify_attributes }}>

            {%- comment -%} Left column: year + label + title + text {%- endcomment -%}
            <div class="timeline__col-text">
              <div class="timeline__meta">
                {%- if block.settings.label != blank -%}
                  <span class="timeline__item-kicker">{{ block.settings.label }}</span>
                {%- endif -%}
                {%- if block.settings.year != blank -%}
                  <span class="timeline__year">{{ block.settings.year }}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.title != blank -%}
                <h3 class="typo-card-title timeline__item-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="timeline__item-text">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <span class="timeline__caption">{{ block.settings.caption }}</span>
              {%- endif -%}
            </div>

            {%- comment -%} Right column: up to 2 images {%- endcomment -%}
            {%- if block.settings.image_primary != blank or block.settings.image_secondary != blank -%}
              <div class="timeline__col-media">
                {%- if block.settings.image_primary != blank -%}
                  <div class="timeline__media-wrap timeline__media-wrap--primary">
                    {{ block.settings.image_primary | image_url: width: 900 | image_tag: loading: 'lazy', widths: '400, 600, 900', alt: block.settings.title }}
                  </div>
                {%- endif -%}
                {%- if block.settings.image_secondary != blank -%}
                  <div class="timeline__media-wrap timeline__media-wrap--secondary">
                    {{ block.settings.image_secondary | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 500, 600', alt: block.settings.title }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

          </li>
        {%- endif -%}
      {%- endfor -%}
    </ol>

  </div>
</div>

<script>
  (function () {
    var section = document.currentScript.closest('.timeline') || document.querySelector('.timeline');
    if (!section) return;

    var reveals = section.querySelectorAll('.timeline__reveal');
    var inEditor = window.Shopify && window.Shopify.designMode;

    if (!('IntersectionObserver' in window) || inEditor) {
      reveals.forEach(function (el) { el.classList.add('is-visible'); });
      return;
    }

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    reveals.forEach(function (el) { observer.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Timeline",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "LA NOSTRA STORIA"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Oltre <em>40 anni</em> al servizio dell'arredo italiano</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Dal laboratorio artigiano di Cuneo alla collaborazione con oltre 50 brand internazionali: un percorso costruito progetto dopo progetto."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "milestone",
      "name": "Milestone",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Small label",
          "default": "CAPITOLO 01"
        },
        {
          "type": "text",
          "id": "year",
          "label": "Year",
          "default": "1983"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Le origini"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "La famiglia Bensa apre il primo laboratorio artigiano a Cuneo, specializzato nella lavorazione del legno su misura."
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (optional)"
        },
        {
          "type": "image_picker",
          "id": "image_primary",
          "label": "Image 1 — large"
        },
        {
          "type": "image_picker",
          "id": "image_secondary",
          "label": "Image 2 — small"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline",
      "blocks": [
        {
          "type": "milestone",
          "settings": {
            "label": "CAPITOLO 01",
            "year": "1983",
            "title": "Le origini",
            "description": "La famiglia Bensa apre il primo laboratorio artigiano a Cuneo, specializzato nella lavorazione del legno su misura. Un garage, due mani esperte, una visione.",
            "caption": "Il primo laboratorio — Cuneo, 1983"
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "CAPITOLO 02",
            "year": "1995",
            "title": "Il primo showroom",
            "description": "Nasce lo showroom di Cuneo: un punto di incontro tra artigianato locale e design italiano di alta gamma."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "CAPITOLO 03",
            "year": "2008",
            "title": "La svolta del progetto",
            "description": "Avviamo il servizio di progettazione chiavi in mano, accompagnando i clienti dal primo schizzo alla consegna."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "CAPITOLO 04",
            "year": "2018",
            "title": "Partnership internazionali",
            "description": "Selezioniamo oltre 50 brand italiani e internazionali, diventando punto di riferimento per architetti e interior designer."
          }
        },
        {
          "type": "milestone",
          "settings": {
            "label": "OGGI",
            "year": "2025",
            "title": "Un metodo, una famiglia",
            "description": "Continuiamo a portare avanti un modo di progettare che mette al centro le persone, gli ambienti e i dettagli che fanno la differenza."
          }
        }
      ]
    }
  ]
}
{% endschema %}
