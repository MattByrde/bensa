<link rel="stylesheet" href="{{ 'section-custom-category-pills.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-category-pills.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: #363636;
    padding-top: 0;
    padding-bottom: 0;
  }
{%- endstyle -%}

<div class="category-pills">
  <div class="category-pills__track">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="category-pills__pill" {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}
          {{ block.settings.icon | image_url: width: 40 | image_tag: class: 'category-pills__icon', loading: 'lazy' }}
        {%- else -%}
          <svg class="category-pills__icon category-pills__icon--default" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
            <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9"/>
          </svg>
        {%- endif -%}
        <span class="category-pills__label typo-overline">{{ block.settings.label }}</span>
      </a>
    {%- endfor -%}
  </div>
</div>

<script>
  (function () {
    var siteHeader = document.querySelector('.site-header');
    var navRow = document.querySelector('.site-header__row--nav');
    var sectionEl = document.getElementById('shopify-section-{{ section.id }}');
    if (!sectionEl) return;

    /* Sentinel sits in normal flow just before the section; its top tells us when to stick */
    var sentinel = document.createElement('div');
    sentinel.style.cssText = 'height:0;margin:0;padding:0;border:0;';
    sectionEl.parentNode.insertBefore(sentinel, sectionEl);

    /* Spacer fills the gap when the section is removed from flow */
    var spacer = document.createElement('div');
    spacer.style.display = 'none';
    sectionEl.parentNode.insertBefore(spacer, sectionEl);

    var isStuck = false;

    function getNavH() { return navRow ? navRow.offsetHeight : 0; }

    function applyStuck(stuck) {
      if (stuck === isStuck) return;
      isStuck = stuck;
      var navH = getNavH();
      if (stuck) {
        spacer.style.height = sectionEl.offsetHeight + 'px';
        spacer.style.display = 'block';
        sectionEl.classList.add('is-pills-stuck');
        sectionEl.style.top = navH + 'px';
      } else {
        spacer.style.display = 'none';
        sectionEl.classList.remove('is-pills-stuck');
        sectionEl.style.top = '';
      }
    }

    function checkSticky() {
      var navH = getNavH();
      applyStuck(sentinel.getBoundingClientRect().top <= navH);
    }

    window.addEventListener('scroll', checkSticky, { passive: true });
    window.addEventListener('resize', checkSticky, { passive: true });

    if (window.MutationObserver && siteHeader) {
      new MutationObserver(checkSticky).observe(siteHeader, { attributes: true, attributeFilter: ['class'] });
    }
    if (window.ResizeObserver && navRow) {
      new ResizeObserver(checkSticky).observe(navRow);
    }

    checkSticky();

    document.querySelectorAll('.category-pills__track').forEach(function (track) {
      var isDown = false;
      var startX = 0;
      var startScroll = 0;
      var dragMoved = false;

      function onDown(e) {
        isDown = true;
        dragMoved = false;
        track.classList.add('is-dragging');
        startX = e.clientX;
        startScroll = track.scrollLeft;
      }

      function onMove(e) {
        if (!isDown) return;
        var dx = e.clientX - startX;
        if (Math.abs(dx) > 3) dragMoved = true;
        /* Directly set scrollLeft each frame */
        requestAnimationFrame(function () {
          track.scrollLeft = startScroll - dx;
        });
      }

      function onUp() {
        if (!isDown) return;
        isDown = false;
        track.classList.remove('is-dragging');
      }

      track.addEventListener('mousedown', onDown);
      window.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);

      /* Prevent native drag on links/images */
      track.addEventListener('dragstart', function (e) { e.preventDefault(); });

      /* Prevent click navigation when user dragged */
      track.addEventListener('click', function (e) {
        if (dragMoved) {
          e.preventDefault();
          e.stopPropagation();
        }
      }, true);
    });
  })();
</script>

{% schema %}
{
  "name": "Category Pills",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "category_pill",
      "name": "Category Pill",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Outline SVG or PNG"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "SEDIE"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Pills",
      "blocks": [
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" },
        { "type": "category_pill" }
      ]
    }
  ]
}
{% endschema %}
