{{ 'section-custom-vision.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    border-top: 1px solid #333;
  }
  .vision-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="vision-section">
  {%- if section.settings.heading_light != blank or section.settings.heading_bold != blank -%}
    <h2 class="vision-heading typo-h2">
      {%- if section.settings.heading_light != blank -%}
        <span class="vision-heading__light">{{ section.settings.heading_light }}</span>
      {%- endif -%}
      {%- if section.settings.heading_bold != blank -%}
        <span class="vision-heading__bold">{{ section.settings.heading_bold }}</span>
      {%- endif -%}
    </h2>
  {%- endif -%}

  {%- if section.settings.subtitle_left != blank or section.settings.subtitle_right != blank -%}
    <div class="vision-subtitle-row">
      {%- if section.settings.subtitle_left != blank -%}
        <p class="vision-subtitle">{{ section.settings.subtitle_left }}</p>
      {%- endif -%}
      {%- if section.settings.subtitle_right != blank -%}
        <p class="vision-subtitle">{{ section.settings.subtitle_right }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="vision-columns">
      {%- for block in section.blocks -%}
        <div class="vision-block" {{ block.shopify_attributes }}>
          {%- if block.settings.number != blank -%}
            <span class="vision-block__number">{{ block.settings.number }}</span>
          {%- endif -%}
          <div class="vision-block__content">
            {%- if block.settings.title != blank -%}
              <p class="vision-block__title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.text_1 != blank -%}
              <p class="vision-block__text">{{ block.settings.text_1 }}</p>
            {%- endif -%}
            {%- if block.settings.text_2 != blank -%}
              <p class="vision-block__text">{{ block.settings.text_2 }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Vision",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 140
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "text",
      "id": "heading_light",
      "label": "Heading (light)",
      "default": "Ownest"
    },
    {
      "type": "text",
      "id": "heading_bold",
      "label": "Heading (bold)",
      "default": "design"
    },
    {
      "type": "textarea",
      "id": "subtitle_left",
      "label": "Subtitle (left)"
    },
    {
      "type": "textarea",
      "id": "subtitle_right",
      "label": "Subtitle (right)"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Column",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text_1",
          "label": "Paragraph 1"
        },
        {
          "type": "textarea",
          "id": "text_2",
          "label": "Paragraph 2"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Vision",
      "settings": {
        "heading_light": "Ownest",
        "heading_bold": "design"
      },
      "blocks": [
        {
          "type": "column",
          "settings": {
            "number": "01",
            "text_1": "Crediamo che il benessere dell'umanità e del pianeta vadano di pari passo. Ogni decisione che prendiamo riflette la nostra coerenza con questi valori, attraverso la trasparenza e il rispetto per ciò che ci circonda.",
            "text_2": "Il nostro scopo è ridefinire il significato di \"proprio\", dove ogni scelta, ogni pezzo, riflette non solo appartenenza, ma anche responsabilità verso il mondo in cui viviamo."
          }
        },
        {
          "type": "column",
          "settings": {
            "number": "02",
            "title": "La nostra essenza.",
            "text_1": "Progettiamo con lo scopo di riconnetterci con ciò che è veramente umano e rispondere ai bisogni del pianeta con onestà e integrità come nostre guide."
          }
        }
      ]
    }
  ]
}
{% endschema %}
