{%- comment -%} Testimonials Section — 5-col grid, center fixed {%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="testi-section" data-testimonial-slider>
  <div class="testi-section__grid">

    {%- comment -%} Carousel — 3 review cards visible on desktop {%- endcomment -%}
    <div class="testi-section__col testi-section__col--side">
      <div class="testi-section__track" data-testi-track>
        {%- for block in section.blocks -%}
          <div class="testi-section__card" {{ block.shopify_attributes }}>
            <div class="testi-section__card-inner">
              <div class="testi-section__quote-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" opacity="0.3"><path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z"/></svg>
              </div>
              {%- if block.settings.quote != blank -%}
                <blockquote class="testi-section__quote typo-body">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
              {%- endif -%}
              <div class="testi-section__author-row">
                <div class="testi-section__avatar">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 300 | image_tag: class: 'testi-section__avatar-img', loading: 'lazy' }}
                  {%- else -%}
                    <div class="testi-section__avatar-placeholder">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" fill="currentColor"/></svg>
                    </div>
                  {%- endif -%}
                </div>
                <div class="testi-section__author-info">
                  {%- if block.settings.author != blank -%}
                    <span class="testi-section__author-name typo-small">{{ block.settings.author }}</span>
                  {%- endif -%}
                  {%- if block.settings.verified -%}
                    <span class="testi-section__verified typo-caption">
                      <svg width="12" height="12" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="7" fill="#fff"/><path d="M4 7l2 2 4-4" stroke="#202020" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      Verified
                    </span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Right fixed text block {%- endcomment -%}
    <div class="testi-section__col testi-section__col--center">
      <div class="testi-section__text">
        {%- if section.settings.subtitle != blank -%}
          <p class="testi-section__subtitle typo-overline">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="testi-section__heading typo-h2">{{ section.settings.heading | newline_to_br }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="testi-section__description typo-small">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.blocks.size > 1 -%}
          <div class="testi-section__nav">
            <button class="testi-section__arrow" data-testi-prev aria-label="Previous review">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11.25 13.5L6.75 9L11.25 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="testi-section__arrow" data-testi-next aria-label="Next review">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M6.75 13.5L11.25 9L6.75 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <span class="testi-section__counter typo-caption" data-testi-counter></span>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('[data-testimonial-slider]').forEach(function (section) {
      var track = section.querySelector('[data-testi-track]');
      if (!track) return;

      if (track.children.length < 1) return;

      var current = 0;
      var counterEl = section.querySelector('[data-testi-counter]');

      function getPerView() {
        if (window.innerWidth >= 990) return 3;
        if (window.innerWidth >= 750) return 2;
        return 1;
      }

      function getTotalPages() {
        var perView = getPerView();
        return Math.max(1, track.children.length - perView + 1);
      }

      function updateCounter() {
        if (counterEl) {
          var pages = getTotalPages();
          counterEl.textContent = (current + 1) + ' / ' + pages;
        }
      }

      function goTo(idx, animate) {
        var pages = getTotalPages();
        current = ((idx % pages) + pages) % pages;

        var card = track.children[0];
        if (!card) return;
        var w = card.offsetWidth;

        if (animate === false) {
          track.style.transition = 'none';
          track.offsetHeight;
        } else {
          track.style.transition = '';
        }
        track.style.transform = 'translateX(' + (-current * w) + 'px)';
        updateCounter();
      }

      updateCounter();

      section.addEventListener('click', function (e) {
        var prev = e.target.closest('[data-testi-prev]');
        var next = e.target.closest('[data-testi-next]');
        if (prev) goTo(current - 1);
        else if (next) goTo(current + 1);
      });

      /* Auto-advance every 5s */
      var autoTimer = setInterval(function () { goTo(current + 1); }, 5000);
      section.addEventListener('mouseenter', function () { clearInterval(autoTimer); });
      section.addEventListener('mouseleave', function () {
        autoTimer = setInterval(function () { goTo(current + 1); }, 5000);
      });

      window.addEventListener('resize', function () { goTo(current, false); });
    });
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#202020"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "RECENSIONI"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Cosa dicono\ni nostri clienti"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Le opinioni di chi ha scelto i nostri prodotti per la propria casa."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This charming piece is perfect for pairing with the matching leggings to create a coordinated and stylish total look."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Ruth Kettling"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Customer",
          "default": true
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
