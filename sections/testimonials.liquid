{%- comment -%} Testimonials Slider Section {%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<section class="section-padding" data-section-id="{{ section.id }}" data-testimonial-slider data-testi-total="{{ section.blocks.size }}">
  <div class="testi-slider">

    {%- comment -%} Slides {%- endcomment -%}
    <div class="testi-slider__slides">
      {%- for block in section.blocks -%}
        <div class="testi-slider__slide{% if forloop.first %} is-active{% endif %}" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="testi-slider__left">
            <div class="testi-slider__avatar">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: class: 'testi-slider__avatar-img', loading: 'lazy' }}
              {%- else -%}
                <div class="testi-slider__avatar-placeholder">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none"><path d="M12 12c2.7 0 5-2.3 5-5s-2.3-5-5-5-5 2.3-5 5 2.3 5 5 5zm0 2c-3.3 0-10 1.7-10 5v2h20v-2c0-3.3-6.7-5-10-5z" fill="currentColor"/></svg>
                </div>
              {%- endif -%}
            </div>
            <div class="testi-slider__text">
              {%- if block.settings.quote != blank -%}
                <blockquote class="testi-slider__quote typo-h2">&ldquo;{{ block.settings.quote }}&rdquo;</blockquote>
              {%- endif -%}
              <div class="testi-slider__meta">
                {%- if block.settings.author != blank -%}
                  <span class="testi-slider__author typo-small">{{ block.settings.author }}</span>
                {%- endif -%}
                {%- if block.settings.verified -%}
                  <span class="testi-slider__verified typo-small">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="7" fill="#333"/><path d="M4 7l2 2 4-4" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Verify Customer
                  </span>
                {%- endif -%}
              </div>
              {%- comment -%} Controls inside each slide's text area {%- endcomment -%}
              {%- if section.blocks.size > 1 -%}
                <div class="testi-slider__controls">
                  <div class="testi-slider__counter typo-caption">
                    <span data-testi-current>1</span>/<span data-testi-total>{{ section.blocks.size }}</span>
                  </div>
                  <div class="testi-slider__progress">
                    <div class="testi-slider__progress-bar" data-testi-bar style="width: {{ 100.0 | divided_by: section.blocks.size }}%"></div>
                  </div>
                  <div class="testi-slider__arrows">
                    <button class="testi-slider__arrow" data-testi-prev aria-label="Previous review">
                      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M11.25 13.5L6.75 9L11.25 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <button class="testi-slider__arrow" data-testi-next aria-label="Next review">
                      <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M6.75 13.5L11.25 9L6.75 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                  </div>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

<script>
  (function () {
    document.querySelectorAll('[data-testimonial-slider]').forEach(function (section) {
      var slides = Array.from(section.querySelectorAll('[data-slide-index]'));
      if (slides.length < 2) return;

      var current = 0;
      var total = slides.length;
      var animating = false;
      var autoplayInterval = null;
      var AUTOPLAY_DELAY = 5000;

      function getCounterEls() {
        return section.querySelectorAll('[data-testi-current]');
      }
      function getBarEls() {
        return section.querySelectorAll('[data-testi-bar]');
      }

      function updateCounters() {
        getCounterEls().forEach(function (el) { el.textContent = current + 1; });
        getBarEls().forEach(function (el) {
          el.style.transition = 'none';
          el.style.width = '0%';
          /* Force reflow then animate to full width over the autoplay interval */
          void el.offsetWidth;
          el.style.transition = 'width ' + (AUTOPLAY_DELAY / 1000) + 's linear';
          el.style.width = '100%';
        });
      }

      function assignPreviews(activeIdx) {
        var remaining = total - 1 - activeIdx;
        slides.forEach(function (slide, idx) {
          if (idx <= activeIdx) return;
          var offset = idx - activeIdx;
          if (offset === 1 && remaining >= 1) slide.classList.add('is-next-1');
          else if (offset === 2 && remaining >= 2) slide.classList.add('is-next-2');
          else if (offset === 3 && remaining >= 3) slide.classList.add('is-next-3');
        });
      }

      function updateClasses() {
        slides.forEach(function (slide) {
          slide.classList.remove('is-active', 'is-next-1', 'is-next-2', 'is-next-3', 'is-exiting', 'is-sliding-in', 'is-sliding-out');
        });
        slides[current].classList.add('is-active');
        assignPreviews(current);
      }

      function goTo(idx, direction) {
        if (animating) return;
        var prev = current;
        var next = (idx + total) % total;
        if (prev === next) return;

        var goingForward = direction !== undefined ? direction === 'next' : next > prev;
        animating = true;
        var prevSlide = slides[prev];
        var nextSlide = slides[next];

        slides.forEach(function (s) {
          s.classList.remove('is-active', 'is-next-1', 'is-next-2', 'is-next-3', 'is-exiting', 'is-sliding-in', 'is-sliding-out');
        });

        /* Direction-aware slide classes */
        if (goingForward) {
          prevSlide.classList.add('is-sliding-out');
          nextSlide.classList.add('is-active', 'is-sliding-in');
        } else {
          prevSlide.classList.add('is-sliding-out-reverse');
          nextSlide.classList.add('is-active', 'is-sliding-in-reverse');
        }

        assignPreviews(next);

        current = next;
        updateCounters();

        setTimeout(function () {
          prevSlide.classList.remove('is-sliding-out', 'is-sliding-out-reverse');
          nextSlide.classList.remove('is-sliding-in', 'is-sliding-in-reverse');
          animating = false;
        }, 500);
      }

      /* Autoplay */
      function startAutoplay() {
        stopAutoplay();
        autoplayInterval = setInterval(function () {
          goTo(current + 1, 'next');
        }, AUTOPLAY_DELAY);
      }

      function stopAutoplay() {
        if (autoplayInterval) {
          clearInterval(autoplayInterval);
          autoplayInterval = null;
        }
      }

      function resetAutoplay() {
        stopAutoplay();
        startAutoplay();
      }

      updateClasses();
      updateCounters();
      startAutoplay();

      /* Pause on hover, resume on leave */
      section.addEventListener('mouseenter', stopAutoplay);
      section.addEventListener('mouseleave', startAutoplay);

      /* Pause when not visible */
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) stopAutoplay();
        else startAutoplay();
      });

      /* Delegate click events for prev/next buttons */
      section.addEventListener('click', function (e) {
        var prev = e.target.closest('[data-testi-prev]');
        var next = e.target.closest('[data-testi-next]');
        if (prev) { goTo(current - 1, 'prev'); resetAutoplay(); }
        else if (next) { goTo(current + 1, 'next'); resetAutoplay(); }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f3ec"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This charming piece is perfect for pairing with the matching leggings to create a coordinated and stylish total look."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Ruth Kettling"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Customer",
          "default": true
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
