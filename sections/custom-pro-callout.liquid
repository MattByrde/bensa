{{ 'section-custom-pro-callout.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }
  #shopify-section-{{ section.id }} .pro-callout__media {
    background-color: {{ section.settings.media_color }};
  }
{%- endstyle -%}

<div class="pro-callout" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="pro-callout__header">
    {%- if section.settings.heading != blank -%}
      <h2 class="pro-callout__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link | default: '#' }}" class="pro-callout__cta">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

  <div class="pro-callout__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: image_size: '2400x', autoplay: true, loop: true, muted: true, controls: false, class: 'pro-callout__video' }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'lazy', widths: '750, 1100, 1500, 2000, 2400', alt: section.settings.heading }}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Pro Callout",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Colore sfondo",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "Sei un Architetto, Geometra o Professionista del Settore?"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Scopri di più"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Immagine (fallback se nessun video)"
    },
    {
      "type": "color",
      "id": "media_color",
      "label": "Colore pannello (se senza immagine)",
      "default": "#cfe2e6"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Pro Callout"
    }
  ]
}
{% endschema %}
