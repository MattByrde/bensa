{{ 'section-custom-ristrutturazioni-values.css' | asset_url | stylesheet_tag }}

<style>
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
  }
</style>

<div class="ristr-values" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  {%- if section.settings.heading != blank -%}
    <h2 class="ristr-values__heading typo-h2">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="ristr-values__grid">
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'text_card' -%}
          <div class="ristr-values__card ristr-values__card--text" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h3 class="ristr-values__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="ristr-values__description">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>

        {%- when 'image_card' -%}
          <div class="ristr-values__card ristr-values__card--image" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'ristr-values__img' }}
            {%- else -%}
              <div class="ristr-values__placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Ristrutturazioni Values",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "I valori che ci guidano"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "text_card",
      "name": "Text Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Viaggio appassionato"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "image_card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Ristrutturazioni Values",
      "blocks": [
        { "type": "text_card", "settings": { "title": "Viaggio appassionato", "description": "Il nostro viaggio è una storia di vero amore per il design, che ha dato vita a un marchio elegante e diversificato." } },
        { "type": "text_card", "settings": { "title": "Squadra unita", "description": "La nostra forza risiede nello spirito collaborativo e in una curiosità insaziabile." } },
        { "type": "image_card" },
        { "type": "text_card", "settings": { "title": "Ispirazioni globali", "description": "Le nostre esperienze, ricche e internazionali, attingono dalla varietà delle culture mondiali." } },
        { "type": "image_card" },
        { "type": "text_card", "settings": { "title": "Sviluppo sostenibile", "description": "Diamo priorità alla sostenibilità, abbracciando pratiche ecologiche insieme alla migliore maestria artigianale." } },
        { "type": "image_card" },
        { "type": "text_card", "settings": { "title": "Invito alla creatività", "description": "Le nostre collezioni invitano alla creazione di interni armoniosi e confortevoli." } }
      ]
    }
  ]
}
{% endschema %}
