{%- comment -%} Main Page Section {%- endcomment -%}

<section class="section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="article-page">
      <h1 class="article-page__title">{{ page.title }}</h1>
      <div class="article-page__content">
        {{ page.content }}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Page content",
  "class": "section-page"
}
{% endschema %}
