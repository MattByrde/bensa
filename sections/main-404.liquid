{%- comment -%} 404 Section {%- endcomment -%}

<section class="section-padding" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="page-404">
      <p class="page-404__title">404</p>
      <h1 class="page-404__heading">{{ '404.title' | t }}</h1>
      <p class="page-404__text">{{ '404.subtitle' | t }}</p>
      <a href="/" class="btn btn--primary">{{ '404.button' | t }}</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404 page",
  "class": "section-404"
}
{% endschema %}
