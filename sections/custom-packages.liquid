<link rel="stylesheet" href="{{ 'section-custom-packages.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-packages.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} .packages__header {
    background-color: {{ section.settings.header_bg_color }};
    color: {{ section.settings.header_text_color }};
  }
  #shopify-section-{{ section.id }} .packages__subtitle {
    color: {{ section.settings.subtitle_color }};
  }
  #shopify-section-{{ section.id }} .packages__card {
    background-color: {{ section.settings.card_bg_color }};
    color: {{ section.settings.card_text_color }};
  }
  #shopify-section-{{ section.id }} .packages__cta {
    background-color: {{ section.settings.cta_bg_color }};
    color: {{ section.settings.cta_text_color }};
  }
{%- endstyle -%}

<div class="packages">
  {%- comment -%} Header {%- endcomment -%}
  <div class="packages__header">
    <div class="packages__header-layout">
      {%- if section.settings.heading != blank -%}
        <h2 class="packages__heading typo-h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Cards grid {%- endcomment -%}
  <div class="packages__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'service_card' -%}
        <div class="packages__card" {{ block.shopify_attributes }}>
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'packages__card-media' }}
          {%- elsif block.settings.icon != blank -%}
            {{ block.settings.icon | image_url: width: 400 | image_tag: class: 'packages__card-media', loading: 'lazy' }}
          {%- else -%}
            <div class="packages__card-icon-placeholder"></div>
          {%- endif -%}

          <div class="packages__card-bottom">
            {%- if block.settings.title != blank -%}
              <h3 class="packages__card-title typo-h3">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.label != blank -%}
              <p class="packages__card-label typo-small">{{ block.settings.label }}</p>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="packages__card-desc typo-small">{{ block.settings.description }}</p>
            {%- endif -%}
          </div>
        </div>

      {%- elsif block.type == 'cta_card' -%}
        <div class="packages__cta" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="packages__cta-heading typo-h1">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link_url }}" class="packages__cta-link typo-small">
              {{ block.settings.link_label }}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 7H13M13 7L7.5 1.5M13 7L7.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Service Packages",
  "tag": "section",
  "class": "section-packages",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Flexible service packages designed to support you at every stage of furnishing your home"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "header_bg_color",
      "label": "Header Background",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "header_text_color",
      "label": "Header Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#1E8BA8"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "cta_bg_color",
      "label": "CTA Card Background",
      "default": "#1E8BA8"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA Card Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Takes priority over image. Autoplays muted and loops."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Image / Illustration"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Name"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Target audience:"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Brief description of the service"
        }
      ]
    },
    {
      "type": "cta_card",
      "name": "CTA Card",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Not sure which service fits you?"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "Get Service Details"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Service Packages",
      "blocks": [
        {
          "type": "service_card",
          "settings": {
            "title": "Interior Consultation",
            "label": "Target audience:",
            "description": "Homeowners looking for expert design advice"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Full Room Design",
            "label": "Target audience:",
            "description": "Clients wanting a complete room transformation"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Custom Furniture",
            "label": "Target audience:",
            "description": "Those seeking bespoke, made-to-order pieces"
          }
        },
        {
          "type": "cta_card",
          "settings": {
            "heading": "Not sure which service fits you?",
            "link_label": "Get Service Details"
          }
        }
      ]
    }
  ]
}
{% endschema %}
