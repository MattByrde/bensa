<link rel="stylesheet" href="{{ 'section-custom-packages.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-packages.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color | default: '#ffffff' }};
    color: {{ section.settings.text_color | default: '#000000' }};
  }
  .scattered-about__content {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .scattered-about__content {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="scattered-about">
  <div class="scattered-about__content">
    <div class="scattered-about__left">
      {%- if section.settings.main_heading != blank -%}
        <h3 class="typo-section-heading scattered-about__heading">{{ section.settings.main_heading }}</h3>
      {%- endif -%}
      {%- if section.settings.header_btn_label != blank -%}
        <a href="{{ section.settings.header_btn_link | default: '#' }}" class="scattered-about__btn">
          {{ section.settings.header_btn_label }}
        </a>
      {%- endif -%}
    </div>
    <div class="scattered-about__right">
      {%- for block in section.blocks -%}
        <div class="scattered-about__service" {{ block.shopify_attributes }}>
          <div class="scattered-about__service-number">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</div>
          <div class="scattered-about__service-body">
            {%- if block.settings.title != blank -%}
              <h3 class="typo-card-title values-card__title scattered-about__service-title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="scattered-about__service-text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Services List",
  "tag": "section",
  "class": "section-scattered-about",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "richtext",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "<p>Cosa Facciamo —<br>I Nostri <em>Servizi</em></p>"
    },
    {
      "type": "text",
      "id": "header_btn_label",
      "label": "Button Label",
      "default": "Scopri i nostri servizi"
    },
    {
      "type": "url",
      "id": "header_btn_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Progettazione d'Interni"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Consulenza completa per la progettazione degli spazi, dalla scelta dei materiali alla definizione delle finiture, con rendering 3D e supporto tecnico dedicato."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services List",
      "blocks": [
        { "type": "service", "settings": { "title": "Progettazione d'Interni", "text": "Consulenza completa per la progettazione degli spazi, dalla scelta dei materiali alla definizione delle finiture, con rendering 3D e supporto tecnico dedicato." } },
        { "type": "service", "settings": { "title": "Arredamento su Misura", "text": "Soluzioni personalizzate per ogni ambiente, con accesso a oltre 50 brand italiani e internazionali. Dal living alla zona notte, ogni dettaglio è curato." } },
        { "type": "service", "settings": { "title": "Ristrutturazioni Chiavi in Mano", "text": "Gestione completa del progetto di ristrutturazione: rilievo misure, coordinamento dei lavori, consegna e montaggio con personale qualificato." } }
      ]
    }
  ]
}
{% endschema %}
