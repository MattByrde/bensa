<link rel="stylesheet" href="{{ 'section-custom-packages.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-custom-packages.css' | asset_url | stylesheet_tag }}</noscript>

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="packages" data-packages-section>
  {%- comment -%} Header {%- endcomment -%}
  <div class="packages__header">
    <div class="packages__header-layout">
      {%- if section.settings.heading != blank -%}
        <h2 class="packages__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <div class="packages__cta-arrows">
        <button class="packages__arrow packages__arrow--prev" data-packages-prev aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="packages__arrow packages__arrow--next" data-packages-next aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </div>

  {%- comment -%} Fixed CTA + scrollable service cards {%- endcomment -%}
  <div class="packages__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'cta_card' -%}
        <div class="packages__cta" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h3 class="packages__cta-heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if section.settings.btn_primary_label != blank -%}
            <a href="{{ section.settings.btn_primary_url | default: '#' }}" class="packages__cta-btn">
              {{ section.settings.btn_primary_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    <div class="packages__carousel" data-packages-carousel>
      <div class="packages__track" data-packages-track>
        {%- for block in section.blocks -%}
          {%- if block.type == 'service_card' -%}
            <div class="packages__card{% if block.settings.video != blank or block.settings.icon != blank %} packages__card--has-media{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, preload: 'none', class: 'packages__card-bg' }}
              {%- elsif block.settings.icon != blank -%}
                {{ block.settings.icon | image_url: width: 800 | image_tag: class: 'packages__card-bg', loading: 'lazy' }}
              {%- else -%}
                <div class="packages__card-bg-placeholder"></div>
              {%- endif -%}

              {%- if block.settings.video != blank -%}
                <button class="packages__mute-btn" data-packages-mute aria-label="Attiva/disattiva audio">
                  <svg class="packages__icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><line x1="23" y1="9" x2="17" y2="15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><line x1="17" y1="9" x2="23" y2="15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                  <svg class="packages__icon-unmuted" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M11 5L6 9H2v6h4l5 4V5z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </button>
              {%- endif -%}

              <div class="packages__card-top">
                {%- if block.settings.label != blank -%}
                  <p class="packages__card-label typo-overline">{{ block.settings.label }}</p>
                {%- endif -%}
              </div>

              <div class="packages__card-bottom">
                {%- if block.settings.title != blank -%}
                  <h3 class="packages__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}

                <div class="packages__card-buttons">
                  {%- if block.settings.button_label != blank -%}
                    <a
                      href="{{ block.settings.button_link }}"
                      class="packages__card-btn typo-small"
                    >
                      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M1 7H13M13 7L7.5 1.5M13 7L7.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {{ block.settings.button_label }}
                    </a>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    /* Mute buttons */
    document.querySelectorAll('[data-packages-mute]').forEach(function (btn) {
      var card = btn.closest('.packages__card');
      var video = card && card.querySelector('video');
      if (!video) return;

      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        video.muted = !video.muted;
        card.classList.toggle('is-unmuted', !video.muted);
      });
    });

    /* Carousel arrows */
    var carousel = document.querySelector('#shopify-section-{{ section.id }} [data-packages-carousel]');
    if (!carousel) return;

    var section = document.querySelector('#shopify-section-{{ section.id }}');
    var prevBtn = section.querySelector('[data-packages-prev]');
    var nextBtn = section.querySelector('[data-packages-next]');
    var track = carousel.querySelector('[data-packages-track]');
    if (!track) return;

    function getScrollAmount() {
      var card = track.querySelector('.packages__card');
      return card ? card.offsetWidth + 16 : 400;
    }

    function updateArrows() {
      var scrollLeft = carousel.scrollLeft;
      var maxScroll = carousel.scrollWidth - carousel.clientWidth;
      if (prevBtn) prevBtn.classList.toggle('is-hidden', scrollLeft <= 2);
      if (nextBtn) nextBtn.classList.toggle('is-hidden', scrollLeft >= maxScroll - 2);
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', function () {
        carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function () {
        carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
    }

    carousel.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  })();
</script>

{% schema %}
{
  "name": "Service Packages",
  "tag": "section",
  "class": "section-packages",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Services"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Flexible service packages designed to support you at every stage of furnishing your home"
    },
    {
      "type": "header",
      "content": "Header Buttons"
    },
    {
      "type": "text",
      "id": "btn_secondary_label",
      "label": "Left Button Label (outlined)"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Left Button URL"
    },
    {
      "type": "text",
      "id": "btn_primary_label",
      "label": "Right Button Label (primary)"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Right Button URL"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Takes priority over image. Autoplays muted and loops."
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Image / Illustration"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Name"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Target audience:"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Scopri"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    },
    {
      "type": "cta_card",
      "name": "CTA Card",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Not sure which service fits you?"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "Get Service Details"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Service Packages",
      "blocks": [
        {
          "type": "service_card",
          "settings": {
            "title": "Interior Consultation",
            "label": "Target audience:"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Full Room Design",
            "label": "Target audience:"
          }
        },
        {
          "type": "service_card",
          "settings": {
            "title": "Custom Furniture",
            "label": "Target audience:"
          }
        },
        {
          "type": "cta_card",
          "settings": {
            "heading": "Not sure which service fits you?",
            "link_label": "Get Service Details"
          }
        }
      ]
    }
  ]
}
{% endschema %}
