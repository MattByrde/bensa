{{ 'section-custom-featured-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="cfg-wrapper">
  <div class="cfg-grid">

    {%- comment -%} Service Cards {%- endcomment -%}
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="cfg-card" {{ block.shopify_attributes }}>
        <h4 class="typo-card-title cfg-card-title">{{ block.settings.title }}</h4>

        {%- if block.settings.description != blank -%}
          <p class="cfg-card-description">{{ block.settings.description }}</p>
        {%- endif -%}

        <div class="cfg-card-footer">
          <span class="cfg-card-label">{{ block.settings.label }}</span>
          <span class="cfg-card-arrow" aria-label="{{ block.settings.link_label | default: 'Scopri di più' }}">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </div>
      </a>
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Services Shortcut Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "COSA FACCIAMO"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "I nostri servizi"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "TUTTI I SERVIZI"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Service Title",
          "default": "Progettazione"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Short Description",
          "default": "Progettiamo insieme il tuo spazio ideale."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category Label",
          "default": "DESIGN"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Text",
          "default": "Scopri di più"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Service Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Services Shortcut Grid",
      "blocks": [
        {
          "type": "service_card",
          "settings": { "title": "Progettazione d'interni", "description": "Progettiamo insieme il tuo spazio ideale, dal concept alla realizzazione.", "label": "DESIGN" }
        },
        {
          "type": "service_card",
          "settings": { "title": "Consulenza personalizzata", "description": "Ti guidiamo nella scelta dei materiali, colori e stili più adatti.", "label": "SUPPORTO" }
        },
        {
          "type": "service_card",
          "settings": { "title": "Consegna e montaggio", "description": "Consegna rapida e installazione professionale a domicilio.", "label": "LOGISTICA" }
        },
        {
          "type": "service_card",
          "settings": { "title": "Preventivi su misura", "description": "Preventivi gratuiti e senza impegno per ogni progetto.", "label": "PREVENTIVI" }
        }
      ]
    }
  ]
}
{% endschema %}
